---
interface Props {
  id: string
  title?: string
  height?: string
  heightMobile?: string
}
const {
  id,
  title,
  height = '450px',
  heightMobile = '280px',
} = Astro.props
---

<div class="mt-10">
  {title && <h2 class="text-sm font-bold text-muted uppercase tracking-widest mb-4">{title}</h2>}
  <div
    id={id}
    class="map-el rounded-xl overflow-hidden border border-border"
    style={`height: ${height}`}
  ></div>
</div>

<style define:vars={{ heightMobile }}>
  @media (max-width: 768px) {
    .map-el { height: var(--heightMobile) !important; }
  }
</style>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
