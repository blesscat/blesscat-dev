---
interface Props {
  title: string;
  subtitle?: string;
}
const { title, subtitle } = Astro.props;
---

<div class="page-header">
  <h1>{title}</h1>
  {subtitle && <p class="subtitle">{subtitle}</p>}
</div>

<style>
  .page-header {
    margin-bottom: 2rem;
  }
  .page-header h1 {
    font-size: 1.75rem;
    font-weight: 800;
    color: #e2e8f0;
    margin: 0 0 0.35rem;
  }
  .subtitle {
    color: #64748b;
    margin: 0;
    font-size: 0.95rem;
  }
</style>
