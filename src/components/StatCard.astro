---
interface Props {
  value: string | number
  label: string
  sub?: string
  target?: number
  decimals?: number
  suffix?: string
  delay?: number
  color?: string
}
const {
  value,
  label,
  sub,
  target,
  decimals = 0,
  suffix = '',
  delay = 1,
  color = '#38bdf8',
} = Astro.props
---

<div class={`bg-surface2 border border-border rounded-xl p-5 text-center anim-fade-up delay-${delay}`}>
  <div
    class:list={['text-3xl font-extrabold leading-tight', target != null ? 'count-up' : '']}
    data-target={target}
    data-decimals={decimals}
    data-suffix={suffix}
    style={`color: ${color}`}
  >
    {value}
  </div>
  <div class="text-xs text-subtle uppercase tracking-widest mt-1">{label}</div>
  {sub && <div class="text-xs text-faint mt-0.5">{sub}</div>}
</div>
