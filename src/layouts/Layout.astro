---
import '../styles/global.css';

export interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} · blesscat.dev</title>
</head>
<body class="bg-[#0a0e1a] text-[#e2e8f0] min-h-screen font-sans">
  <nav class="sticky top-0 z-50 flex items-center justify-between px-4 sm:px-8 py-4 border-b border-[#1e2535] bg-[#0a0e1a]/95 backdrop-blur">
    <a href="/" class="nav-logo text-[#38bdf8] font-bold text-lg no-underline">🐱 <span class="nav-brand-text">blesscat.dev</span></a>
    <ul class="flex gap-3 sm:gap-8 list-none">
      <li><a href="/dives" class="nav-link text-[#94a3b8] text-sm hover:text-[#e2e8f0] transition-colors no-underline"><span class="nav-icon">🤿</span><span class="nav-text"> 潛水</span></a></li>
      <li><a href="/ski" class="nav-link text-[#94a3b8] text-sm hover:text-[#e2e8f0] transition-colors no-underline"><span class="nav-icon">⛷️</span><span class="nav-text"> 滑雪</span></a></li>
      <li><a href="/explore" class="nav-link text-[#94a3b8] text-sm hover:text-[#e2e8f0] transition-colors no-underline"><span class="nav-icon">🌏</span><span class="nav-text"> 探索</span></a></li>
      <li><a href="/blog" class="nav-link text-[#94a3b8] text-sm hover:text-[#e2e8f0] transition-colors no-underline"><span class="nav-icon">📝</span><span class="nav-text"> 日記</span></a></li>
    </ul>
  </nav>
  <main class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
    <slot />
  </main>
</body>
</html>

<style>
  .nav-logo {
    animation: floatY 3.5s ease-in-out infinite;
    display: inline-block;
    white-space: nowrap;
  }

  /* 手機版：隱藏文字，只留 emoji */
  @media (max-width: 480px) {
    .nav-brand-text { display: none; }
    .nav-text { display: none; }
    .nav-icon { font-size: 1.1rem; }
  }
</style>

<script>
  // Scroll-reveal for .reveal elements
  const revealEls = document.querySelectorAll('.reveal');
  if (revealEls.length) {
    const rio = new IntersectionObserver((entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          // stagger siblings slightly
          setTimeout(() => entry.target.classList.add('revealed'), i * 60);
          rio.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    revealEls.forEach(el => rio.observe(el));
  }
</script>
