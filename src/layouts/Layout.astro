---
import '../styles/global.css';

export interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} · blesscat.dev</title>
</head>
<body class="bg-[#0a0e1a] text-[#e2e8f0] min-h-screen font-sans">
  <nav class="sticky top-0 z-50 flex items-center justify-between px-4 sm:px-8 py-4 border-b border-[#1e2535] bg-[#0a0e1a]/95 backdrop-blur">
    <a href="/" class="text-[#38bdf8] font-bold text-lg no-underline">🐱 blesscat.dev</a>
    <ul class="flex gap-4 sm:gap-8 list-none">
      <li><a href="/dives" class="text-[#94a3b8] text-sm hover:text-[#e2e8f0] transition-colors no-underline">🤿 潛水</a></li>
      <li><a href="/ski" class="text-[#94a3b8] text-sm hover:text-[#e2e8f0] transition-colors no-underline">⛷️ 滑雪</a></li>
      <li><a href="/blog" class="text-[#94a3b8] text-sm hover:text-[#e2e8f0] transition-colors no-underline">📝 日記</a></li>
    </ul>
  </nav>
  <main class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
    <slot />
  </main>
</body>
</html>
