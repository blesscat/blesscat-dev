---
import '../styles/global.css'

export interface Props {
  title: string
  description?: string
  ogImage?: string
}
const { title, description = 'Diver · Skier · Explorer · Tinkerer', ogImage } = Astro.props
const site = 'https://blog.blesscat.dev'
const pageTitle = title === 'Home' ? 'blesscat.dev' : `${title} · blesscat.dev`
const ogImageUrl = ogImage ? `${site}${ogImage}` : `${site}/og/index.png`
---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={description} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="blesscat.dev" />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:url" content={`${site}${Astro.url.pathname}`} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#1c1917" />
  <link rel="canonical" href={`${site}${Astro.url.pathname}`} />
  <meta name="google-site-verification" content="3MYOA5lRPf0BHPcWa1_mVvEGsOTCNiit4HX9-SWsYU0" />
  <link rel="alternate" type="application/rss+xml" title="豬毛日記 RSS" href="/rss.xml" />
  <slot name="head" />
  <!-- Prevent dark mode flash: apply theme before first paint -->
  <script is:inline>
    try {
      if (localStorage.getItem('theme') !== 'light') {
        document.documentElement.classList.add('dark');
      }
    } catch (e) {}
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
</head>
<body class="bg-bg text-text min-h-screen font-['Sora',sans-serif]">
  <nav id="top-nav" class="top-nav-bar z-50 flex items-center justify-between px-4 sm:px-8 py-4 border-b border-border bg-bg/95 backdrop-blur">
    <a href="/" class="nav-logo text-accent font-bold text-lg no-underline"><img src="/zhumao-avatar.jpg" class="nav-avatar" alt="豬毛" /> <span class="nav-brand-text">blesscat.dev</span></a>
    <div class="flex items-center gap-2">
      <!-- Dark mode toggle -->
      <button id="theme-toggle" aria-label="切換深色模式" class="theme-toggle w-9 h-9 flex items-center justify-center rounded-lg border border-border text-muted hover:text-text hover:border-[#84e7a5] transition-all duration-200 cursor-pointer">
        <span id="theme-icon-moon" class="text-sm">🌙</span>
        <span id="theme-icon-sun" class="text-sm hidden">☀️</span>
      </button>
      <!-- Search trigger -->
      <button id="search-toggle" aria-label="搜尋文章" class="w-9 h-9 flex items-center justify-center rounded-lg border border-border text-muted hover:text-text hover:border-[#84e7a5] transition-all duration-200 cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      </button>
      <ul class="flex gap-3 sm:gap-8 list-none">
      <li><a href="/dives" class="nav-link text-muted text-sm hover:text-text transition-colors no-underline"><span class="nav-icon">🤿</span><span class="nav-text"> 潛水</span></a></li>
      <li><a href="/ski" class="nav-link text-muted text-sm hover:text-text transition-colors no-underline"><span class="nav-icon">⛷️</span><span class="nav-text"> 滑雪</span></a></li>
      <li><a href="/explore" class="nav-link text-muted text-sm hover:text-text transition-colors no-underline"><span class="nav-icon">🌏</span><span class="nav-text"> 探索</span></a></li>
      <li><a href="/blog" class="nav-link text-muted text-sm hover:text-text transition-colors no-underline"><span class="nav-icon">📝</span><span class="nav-text"> 日記</span></a></li>
    </ul>
    </div>
  </nav>
  <main class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
    <slot />
  </main>
  <nav class="bottom-tab-bar">
    <a href="/" class="tab-item" data-path="/">
      <span class="tab-icon">🏠</span>
      <span class="tab-label">首頁</span>
    </a>
    <a href="/dives" class="tab-item" data-path="/dives">
      <span class="tab-icon">🤿</span>
      <span class="tab-label">潛水</span>
    </a>
    <a href="/ski" class="tab-item" data-path="/ski">
      <span class="tab-icon">⛷️</span>
      <span class="tab-label">滑雪</span>
    </a>
    <a href="/explore" class="tab-item" data-path="/explore">
      <span class="tab-icon">🌏</span>
      <span class="tab-label">探索</span>
    </a>
    <a href="/blog" class="tab-item" data-path="/blog">
      <span class="tab-icon">📝</span>
      <span class="tab-label">日記</span>
    </a>
  </nav>

  <!-- 豬毛探頭 -->
  <div id="zhumao-peek" title="回到頂部 ↑" aria-label="回到頂部"><img src="/zhumao-avatar.jpg" alt="豬毛" class="peek-avatar" /></div>

  <!-- Pagefind search modal -->
  <div id="search-modal" class="search-modal" role="dialog" aria-modal="true" aria-label="搜尋文章" style="display:none;">
    <div class="search-backdrop"></div>
    <div class="search-panel">
      <div class="search-header">
        <input id="search-input" type="search" placeholder="搜尋文章..." autocomplete="off" />
        <button id="search-close" aria-label="關閉搜尋">✕</button>
      </div>
      <div id="search-results" class="search-results"></div>
    </div>
  </div>
  <script is:inline>
    (function() {
      var modal = document.getElementById('search-modal');
      var input = document.getElementById('search-input');
      var results = document.getElementById('search-results');
      var closeBtn = document.getElementById('search-close');
      var pagefind = null;
      var debounceTimer = null;

      function openModal() {
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
        setTimeout(function() { input.focus(); }, 50);
      }

      function closeModal() {
        modal.style.display = 'none';
        document.body.style.overflow = '';
        input.value = '';
        results.innerHTML = '';
      }

      document.getElementById('search-toggle').addEventListener('click', openModal);
      closeBtn.addEventListener('click', closeModal);
      modal.querySelector('.search-backdrop').addEventListener('click', closeModal);

      document.addEventListener('keydown', function(e) {
        if (e.key === '/' && document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA') {
          e.preventDefault();
          openModal();
        }
        if (e.key === 'Escape' && modal.style.display !== 'none') {
          closeModal();
        }
      });

      async function loadPagefind() {
        if (!pagefind) {
          try { pagefind = await import('/pagefind/pagefind.js'); } catch(e) { return; }
        }
        return pagefind;
      }

      input.addEventListener('input', function() {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(search, 200);
      });

      async function search() {
        var q = input.value.trim();
        if (!q) { results.innerHTML = ''; return; }
        var pf = await loadPagefind();
        if (!pf) return;
        var res = await pf.search(q);
        var data = await Promise.all(res.results.slice(0, 10).map(function(r) { return r.data(); }));
        if (data.length === 0) {
          results.innerHTML = '<div class="search-empty">找不到「' + q + '」的結果</div>';
          return;
        }
        results.innerHTML = data.map(function(item) {
          return '<a href="' + item.url + '" class="search-result">' +
            '<div class="search-result-title">' + item.meta.title + '</div>' +
            '<div class="search-result-excerpt">' + item.excerpt + '</div>' +
            '</a>';
        }).join('');
      }
    })();
  </script>
</body>
</html>

<style>
  .nav-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    white-space: nowrap;
    color: #000000;
    font-weight: 600;
  }
  .nav-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid #84e7a5;
    flex-shrink: 0;
  }
  .peek-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    border: 2.5px solid #84e7a5;
    box-shadow: -3px 4px 0px rgba(0,0,0,0.12);
    display: block;
  }

  /* 手機版：隱藏文字，只留 emoji */
  @media (max-width: 480px) {
    .nav-brand-text { display: none; }
    .nav-text { display: none; }
    .nav-icon { font-size: 1.1rem; }
  }

  /* Desktop: sticky，z-index 要高過 Leaflet（預設最高 ~1000） */
  .top-nav-bar {
    position: sticky;
    top: 0;
    z-index: 1100;
    background: rgba(250,249,247,0.95);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid #dad4c8;
  }

  /* 手機版：fixed + transform，transform 才能正常作用 */
  @media (max-width: 768px) {
    .top-nav-bar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 1100;
      transition: transform 0.3s ease;
    }
    .top-nav-bar.nav-hidden {
      transform: translateY(-100%);
      pointer-events: none;
    }
    /* 補上 header 佔位，避免內容被遮 */
    body {
      padding-top: 57px;
    }
  }

  /* ── 豬毛探頭 ── */
  #zhumao-peek {
    position: fixed;
    bottom: -60px;
    right: 24px;
    font-size: 2rem;
    cursor: pointer;
    z-index: 999;
    transition: bottom 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
                transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    animation: swing 2.5s ease-in-out infinite;
    user-select: none;
  }
  #zhumao-peek.peeking {
    bottom: 16px;
  }
  #zhumao-peek.peeking.has-tabbar {
    bottom: 80px;
  }
  #zhumao-peek:hover {
    transform: rotateZ(-6deg) scale(1.05);
  }
  #zhumao-peek::after {
    content: '回到頂部 ↑';
    position: absolute;
    bottom: 110%;
    right: 0;
    background: #ffffff;
    border: 1px solid #dad4c8;
    color: #55534e;
    font-size: 0.75rem;
    padding: 0.3rem 0.6rem;
    border-radius: 8px;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
    font-family: 'Sora', sans-serif;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  }
  #zhumao-peek:hover::after {
    opacity: 1;
  }

  /* Bottom tab bar */
  .bottom-tab-bar {
    display: none;
  }

  @media (max-width: 768px) {
    .bottom-tab-bar {
      display: flex;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 100;
      background: #ffffff;
      border-top: 1px solid #dad4c8;
      height: 60px;
      align-items: stretch;
      box-shadow: 0 -2px 12px rgba(0,0,0,0.04);
    }

    main {
      padding-bottom: 70px;
    }
  }

  .tab-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    text-decoration: none;
    color: #9f9b93;
    font-size: 0.65rem;
    transition: color 0.2s, transform 0.2s;
  }

  .tab-item.active,
  .tab-item:hover {
    color: #000000;
    transform: translateY(-2px);
  }

  .tab-icon {
    font-size: 1.3rem;
    line-height: 1;
  }

  .tab-label {
    line-height: 1;
  }

  @keyframes swing {
    0%, 100% { transform: rotateZ(0deg); }
    30%       { transform: rotateZ(-2deg); }
    70%       { transform: rotateZ(2deg); }
  }
</style>

<script>
  // ── Dark mode toggle ──
  ;(function initTheme() {
    const html = document.documentElement
    const btn = document.getElementById('theme-toggle')
    const moon = document.getElementById('theme-icon-moon')
    const sun = document.getElementById('theme-icon-sun')
    if (!btn || !moon || !sun) return

    function applyTheme(dark: boolean) {
      html.classList.toggle('dark', dark)
      moon.classList.toggle('hidden', dark)
      sun.classList.toggle('hidden', !dark)
      localStorage.setItem('theme', dark ? 'dark' : 'light')
    }

    // Init from localStorage or system preference; default to dark
    const saved = localStorage.getItem('theme')
    // Dark unless user explicitly chose light
    applyTheme(saved !== 'light')

    btn.addEventListener('click', () => {
      applyTheme(!html.classList.contains('dark'))
    })
  })()

  // Scroll-reveal for .reveal elements
  const revealEls = document.querySelectorAll('.reveal')
  if (revealEls.length) {
    const rio = new IntersectionObserver((entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          // stagger siblings slightly
          setTimeout(() => entry.target.classList.add('revealed'), i * 60)
          rio.unobserve(entry.target)
        }
      })
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' })
    revealEls.forEach(el => rio.observe(el))
  }

  // Bottom tab bar active state
  const path = window.location.pathname
  const tabItems = document.querySelectorAll('.tab-item')
  tabItems.forEach(tab => {
    const tabPath = tab.getAttribute('data-path')
    if (tabPath === '/') {
      if (path === '/') tab.classList.add('active')
    } else if (tabPath && path.startsWith(tabPath)) {
      tab.classList.add('active')
    }
  })

  // 手機版 header 捲動淡出
  function initNavHide() {
    const nav = document.getElementById('top-nav')
    if (!nav || window.innerWidth > 768) return
    let lastY = 0
    let ticking = false
    window.addEventListener('scroll', () => {
      if (ticking) return
      ticking = true
      requestAnimationFrame(() => {
        const y = window.scrollY
        // 往下捲超過 60px 才隱藏，往上捲立即顯示
        if (y > lastY && y > 60) {
          nav.classList.add('nav-hidden')
        } else {
          nav.classList.remove('nav-hidden')
        }
        lastY = y
        ticking = false
      })
    }, { passive: true })
  }
  initNavHide()

  // 豬毛探頭
  function initPeekCat() {
    const cat = document.getElementById('zhumao-peek')
    if (!cat) return
    const tabBar = document.querySelector('.bottom-tab-bar')

    function onScroll() {
      if (!cat) return
      const scrolled = window.scrollY + window.innerHeight
      const total = document.documentElement.scrollHeight
      const ratio = total > 0 ? scrolled / total : 0
      if (ratio >= 0.7) {
        cat.classList.add('peeking')
        // 判斷 bottom-tab-bar 是否可見（手機）
        if (tabBar && window.getComputedStyle(tabBar).display !== 'none') {
          cat.classList.add('has-tabbar')
        } else {
          cat.classList.remove('has-tabbar')
        }
      } else {
        cat.classList.remove('peeking')
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true })
    onScroll()

    cat.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' })
    })
  }
  initPeekCat()
</script>

<style>
  /* ── Search Modal ── */
  .search-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: 10vh;
  }
  .search-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.5);
    backdrop-filter: blur(4px);
  }
  .search-panel {
    position: relative;
    width: 90%;
    max-width: 600px;
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 24px 64px rgba(0,0,0,0.2);
    overflow: hidden;
  }
  .search-header {
    display: flex;
    align-items: center;
    padding: 1rem;
    border-bottom: 1px solid #dad4c8;
    gap: 0.5rem;
  }
  #search-input {
    flex: 1;
    border: none;
    outline: none;
    font-size: 1.1rem;
    font-family: 'Sora', sans-serif;
    background: transparent;
    color: #1c1917;
  }
  #search-input::placeholder { color: #9f9b93; }
  #search-close {
    background: none;
    border: none;
    font-size: 1.1rem;
    color: #9f9b93;
    cursor: pointer;
    padding: 0.25rem 0.5rem;
  }
  #search-close:hover { color: #1c1917; }
  .search-results {
    max-height: 60vh;
    overflow-y: auto;
    padding: 0.5rem;
  }
  .search-result {
    display: block;
    padding: 0.75rem;
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
  }
  .search-result:hover { background: #f5f4f0; }
  .search-result-title {
    font-weight: 600;
    color: #1c1917;
    margin-bottom: 0.25rem;
  }
  .search-result-excerpt {
    font-size: 0.875rem;
    color: #6b6560;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .search-empty {
    padding: 2rem;
    text-align: center;
    color: #9f9b93;
  }

  /* dark mode */
  :global(.dark) .search-panel { background: #1c1917; border-color: #2c2926; }
  :global(.dark) .search-header { border-color: #2c2926; }
  :global(.dark) #search-input { color: #f5f4f0; }
  :global(.dark) #search-input::placeholder { color: #6b6560; }
  :global(.dark) #search-close { color: #6b6560; }
  :global(.dark) #search-close:hover { color: #f5f4f0; }
  :global(.dark) .search-result:hover { background: #2c2926; }
  :global(.dark) .search-result-title { color: #f5f4f0; }
  :global(.dark) .search-result-excerpt { color: #9f9b93; }
</style>
