---
import Layout from '../layouts/Layout.astro';
---
<Layout title="404 — 豬毛迷路了">
  <div class="not-found-container">
    <div class="cat-emoji">
      <img src="/zhumao-avatar.jpg" alt="豬毛" class="cat-img" />
    </div>
    <h1 class="title">404 — 豬毛迷路了</h1>
    <p class="subtitle">這個頁面不存在，豬毛也找不到它 (´･ω･`)</p>
    <a href="/" class="btn-home">回首頁</a>
  </div>
</Layout>

<style>
  .not-found-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
    gap: 1.5rem;
  }

  @keyframes swing {
    0%   { transform: rotate(-10deg); }
    50%  { transform: rotate(10deg); }
    100% { transform: rotate(-10deg); }
  }

  .cat-emoji {
    display: inline-block;
    animation: swing 1.4s ease-in-out infinite;
    transform-origin: center bottom;
  }
  .cat-img {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid #38bdf8;
    box-shadow: 0 0 24px rgba(56,189,248,0.4), 0 0 48px rgba(56,189,248,0.15);
    animation: pulse-glow 2.5s ease-in-out infinite;
  }

  .title {
    font-size: 2rem;
    font-weight: 700;
    color: #e2e8f0;
    margin: 0;
  }

  .subtitle {
    font-size: 1.05rem;
    color: #94a3b8;
    margin: 0;
  }

  .btn-home {
    display: inline-block;
    background: #38bdf8;
    color: #0a0e1a;
    font-weight: 600;
    padding: 0.6rem 1.6rem;
    border-radius: 8px;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .btn-home:hover {
    opacity: 0.85;
  }
</style>
