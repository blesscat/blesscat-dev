---
import Layout from '../layouts/Layout.astro';
---
<Layout title="404 — 豬毛迷路了">
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center gap-6">

    <div class="inline-block [animation:swing_1.4s_ease-in-out_infinite] [transform-origin:center_bottom]">
      <img
        src="/zhumao-avatar.jpg"
        alt="豬毛"
        class="w-[140px] h-[140px] rounded-full object-cover border-[3px] border-[#38bdf8] shadow-[0_0_24px_rgba(56,189,248,0.4),0_0_48px_rgba(56,189,248,0.15)] [animation:pulse-glow_2.5s_ease-in-out_infinite]"
      />
    </div>

    <h1 class="text-3xl font-bold text-[#e2e8f0] m-0">404 — 豬毛迷路了</h1>
    <p class="text-[1.05rem] text-[#94a3b8] m-0">這個頁面不存在，豬毛也找不到它 (´･ω･`)</p>

    <a href="/"
       class="inline-block bg-[#38bdf8] text-[#0a0e1a] font-semibold px-6 py-2.5 rounded-lg no-underline transition-opacity hover:opacity-85">
      回首頁
    </a>

  </div>
</Layout>

<style>
  /* swing keyframe — CSS animation，Tailwind 無法定義 keyframe */
  @keyframes swing {
    0%   { transform: rotate(-10deg); }
    50%  { transform: rotate(10deg); }
    100% { transform: rotate(-10deg); }
  }
</style>
