---
import Layout from '../../layouts/Layout.astro'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const posts = await getCollection('blog')
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content } = await render(post)
const displayTitle = post.data.title.replace(/^\d{4}-\d{2}-\d{2}\s+/, '')
const ogImage = `/og/blog/${post.id.replace(/\.md$/, '')}.png`
const ogDesc = post.data.description || displayTitle
const wordCount = (post.body || '').replace(/\s+/g, '').length
const readMinutes = Math.max(1, Math.round(wordCount / 250))
---
<Layout title={displayTitle} description={ogDesc} ogImage={ogImage}>
  <!-- 閱讀進度條 -->
  <div id="reading-progress-bar"
       class="fixed top-[57px] left-0 w-0 h-[3px] bg-[#3bd3fd] z-[9999] transition-[width,top] duration-100 ease-linear"
       style="transition-property: width, top; transition-duration: 100ms, 300ms; transition-timing-function: linear, ease;">
  </div>

  <article class="max-w-2xl mx-auto">

    {post.data.heroImage && (
      <div class="mb-8 flex justify-center">
        <img
          src={post.data.heroImage}
          alt={post.data.title}
          class="w-full sm:w-2/3 sm:max-w-md rounded-2xl object-cover shadow-lg"
        />
      </div>
    )}

    <header class="mb-8 pb-6 border-b border-border">
      <div class="flex items-center justify-between mb-3">
        <div class="flex items-center gap-3">
          <span class="text-xs text-faint">📅 {post.data.date}</span>
          <span class="text-xs text-faint">⏱ 約 {readMinutes} 分鐘</span>
        </div>
        <a href="/blog" class="text-xs text-[#3bd3fd] hover:underline">← 回到列表</a>
      </div>
      <h1 class="text-2xl sm:text-3xl font-extrabold text-#000000 leading-snug mb-4">
        {displayTitle}
      </h1>
      {post.data.tags && (
        <div class="flex flex-wrap gap-2">
          {post.data.tags.map(tag => (
            <span class="text-xs text-#84e7a5 bg-tag-bg px-3 py-1 rounded-full">#{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="prose-content leading-relaxed text-prose">
      <Content />
    </div>

    <div id="remark42" class="remark42-container mt-12 pt-8 border-t border-border"></div>

    <div class="mt-12 pt-8 border-t border-border flex justify-center">
      <button
        id="copy-link-btn"
        class="bg-transparent border border-border text-muted px-6 py-2 rounded-lg text-[0.88rem] cursor-pointer transition-all hover:border-[#3bd3fd] hover:text-[#3bd3fd]"
      >🔗 複製連結</button>
    </div>

  </article>
</Layout>

<script>
  const bar = document.getElementById('reading-progress-bar') as HTMLElement | null
  const nav = document.getElementById('top-nav')

  function updateProgressTop() {
    if (!bar) return
    if (nav && nav.classList.contains('nav-hidden')) {
      bar.style.top = '0px'
    } else {
      bar.style.top = nav ? nav.getBoundingClientRect().height + 'px' : '57px'
    }
  }

  function updateProgress() {
    const scrollTop = window.scrollY
    const docHeight = document.documentElement.scrollHeight - window.innerHeight
    const pct = docHeight > 0 ? Math.min(100, (scrollTop / docHeight) * 100) : 0
    if (bar) bar.style.width = pct + '%'
    updateProgressTop()
  }

  // 監聽 nav 的 class 變化，同步更新進度條位置
  if (nav) {
    const observer = new MutationObserver(() => updateProgressTop())
    observer.observe(nav, { attributes: true, attributeFilter: ['class'] })
  }

  window.addEventListener('scroll', updateProgress, { passive: true })
  updateProgress()

  const copyBtn = document.getElementById('copy-link-btn')
  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href)
        copyBtn.textContent = '✓ 已複製！'
        setTimeout(() => { copyBtn.textContent = '🔗 複製連結'; }, 1500)
      } catch {
        copyBtn.textContent = '✓ 已複製！'
        setTimeout(() => { copyBtn.textContent = '🔗 複製連結'; }, 1500)
      }
    })
  }
</script>

<!-- Remark42 comments - MUST be before embed.js -->
<script is:inline>
  window.remark_config = {
    host: "https://remark42.blesscat.dev",
    site_id: "blog",
    page: window.location.pathname,
    url: window.location.href,
    theme: "dark",
  };
</script>
<script is:inline src="https://remark42.blesscat.dev/web/embed.js"></script>

<style>
  /* prose-content：markdown 渲染的 HTML 無法 inline，必須用 :global() */
  .prose-content :global(h2) {
    font-size: 1.35rem; font-weight: 700; color: var(--color-text);
    margin: 2.5rem 0 1rem; padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .prose-content :global(h3) {
    font-size: 1.1rem; font-weight: 700; color: var(--color-muted);
    margin: 1.5rem 0 0.75rem;
  }
  .prose-content :global(p) { margin-bottom: 1.2rem; }
  .prose-content :global(ul),
  .prose-content :global(ol) { padding-left: 1.5rem; margin-bottom: 1.2rem; }
  .prose-content :global(li) { margin-bottom: 0.4rem; }
  .prose-content :global(code) {
    background: var(--color-surface2); color: var(--color-accent);
    padding: 0.15rem 0.4rem; border-radius: 4px;
    font-size: 0.88em;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
  }
  .prose-content :global(pre) {
    background: var(--color-surface); border: 1px solid var(--color-border);
    border-radius: 10px; padding: 1.2rem 1.5rem;
    overflow-x: auto; margin-bottom: 1.5rem;
  }
  .prose-content :global(pre code) {
    background: none; color: var(--color-prose); padding: 0; font-size: 0.85rem;
  }
  .prose-content :global(blockquote) {
    border-left: 3px solid var(--color-accent); padding-left: 1rem;
    color: var(--color-muted); font-style: italic; margin: 1.2rem 0;
  }
  .prose-content :global(img) { max-width: 100%; border-radius: 10px; margin: 1rem 0; }
  .prose-content :global(hr) { border: none; border-top: 1px solid var(--color-border); margin: 2rem 0; }
  .prose-content :global(strong) { color: var(--color-text); font-weight: 700; }
  .prose-content :global(a) { color: var(--color-accent); text-decoration: none; }
  .prose-content :global(a:hover) { text-decoration: underline; }
  .prose-content :global(table) {
    width: 100%; border-collapse: collapse; margin-bottom: 1.5rem; font-size: 0.9rem;
  }
  .prose-content :global(th) {
    background: var(--color-surface2); padding: 0.6rem 1rem;
    text-align: left; color: var(--color-muted); font-weight: 600;
  }
  .prose-content :global(td) { padding: 0.6rem 1rem; border-bottom: 1px solid var(--color-border); }

  /* ── Dark mode overrides for prose ── */
  html.dark .prose-content :global(h2) {
    color: var(--color-text);
    border-bottom-color: var(--color-border);
  }
  html.dark .prose-content :global(h3) {
    color: var(--color-muted);
  }
  html.dark .prose-content :global(code) {
    background: rgba(91,168,190,0.12);
    color: var(--color-accent);
  }
  html.dark .prose-content :global(pre) {
    background: var(--color-surface);
    border-color: var(--color-border);
  }
  html.dark .prose-content :global(pre code) {
    color: var(--color-prose);
  }
  html.dark .prose-content :global(blockquote) {
    border-left-color: var(--color-accent);
    color: var(--color-muted);
  }
  html.dark .prose-content :global(hr) {
    border-top-color: var(--color-border);
  }
  html.dark .prose-content :global(strong) {
    color: var(--color-text);
  }
  html.dark .prose-content :global(a) {
    color: var(--color-accent);
  }
  html.dark .prose-content :global(th) {
    background: var(--color-surface2);
    color: var(--color-muted);
  }
  html.dark .prose-content :global(td) {
    border-bottom-color: var(--color-border);
  }

  /* ── Remark42 container — blend into Clay Warm palette ── */
  .remark42-container {
    border-radius: 12px;
    overflow: hidden;
  }
</style>
