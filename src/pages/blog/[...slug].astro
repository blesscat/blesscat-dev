---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<Layout title={post.data.title}>
  <article class="post">
    <header class="post-header">
      <div class="post-meta">
        <span class="post-date">📅 {post.data.date}</span>
        <a href="/blog" class="back-link">← 回到列表</a>
      </div>
      <h1 class="post-title">{post.data.title}</h1>
      {post.data.tags && (
        <div class="post-tags">
          {post.data.tags.map(tag => (
            <span class="tag">#{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="post-content">
      <Content />
    </div>
  </article>
</Layout>

<style>
  .post { max-width: 800px; margin: 0 auto; }

  .post-header { margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid #1e2535; }

  .post-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .post-date { font-size: 0.85rem; color: #475569; }
  .back-link { font-size: 0.85rem; color: #38bdf8; text-decoration: none; }
  .back-link:hover { text-decoration: underline; }

  .post-title {
    font-size: 2rem;
    font-weight: 800;
    color: #e2e8f0;
    line-height: 1.3;
    margin-bottom: 1rem;
  }

  .post-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .tag {
    font-size: 0.75rem;
    color: #818cf8;
    background: #1a1a2e;
    padding: 0.2rem 0.6rem;
    border-radius: 99px;
  }

  /* Markdown 內容樣式 */
  .post-content {
    line-height: 1.8;
    color: #cbd5e1;
  }
  .post-content :global(h2) {
    font-size: 1.4rem;
    font-weight: 700;
    color: #e2e8f0;
    margin: 2.5rem 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid #1e2535;
  }
  .post-content :global(h3) {
    font-size: 1.1rem;
    font-weight: 700;
    color: #94a3b8;
    margin: 1.5rem 0 0.75rem;
  }
  .post-content :global(p) {
    margin-bottom: 1.2rem;
  }
  .post-content :global(ul), .post-content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.2rem;
  }
  .post-content :global(li) {
    margin-bottom: 0.4rem;
  }
  .post-content :global(code) {
    background: #1e2535;
    color: #38bdf8;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.88em;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
  }
  .post-content :global(pre) {
    background: #0d1117;
    border: 1px solid #1e2535;
    border-radius: 10px;
    padding: 1.2rem 1.5rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }
  .post-content :global(pre code) {
    background: none;
    color: #e2e8f0;
    padding: 0;
    font-size: 0.85rem;
  }
  .post-content :global(blockquote) {
    border-left: 3px solid #38bdf8;
    padding-left: 1rem;
    color: #64748b;
    font-style: italic;
    margin: 1.2rem 0;
  }
  .post-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }
  .post-content :global(th) {
    background: #1e2535;
    padding: 0.6rem 1rem;
    text-align: left;
    color: #94a3b8;
    font-weight: 600;
  }
  .post-content :global(td) {
    padding: 0.6rem 1rem;
    border-bottom: 1px solid #1e2535;
  }
  .post-content :global(hr) {
    border: none;
    border-top: 1px solid #1e2535;
    margin: 2rem 0;
  }
  .post-content :global(strong) {
    color: #e2e8f0;
    font-weight: 700;
  }
  .post-content :global(a) {
    color: #38bdf8;
    text-decoration: none;
  }
  .post-content :global(a:hover) {
    text-decoration: underline;
  }
</style>
