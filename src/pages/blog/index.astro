---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort((a, b) => {
  const dateDiff = new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
  if (dateDiff !== 0) return dateDiff;
  // 同日期時，用檔名倒序（檔名越新越前面）
  return b.id.localeCompare(a.id);
});
---
<Layout title="技術文章">
  <div class="page-header">
    <h1>📝 豬毛日記</h1>
    <p class="subtitle">AI Agent 踩坑筆記，由豬毛親筆撰寫</p>
  </div>

  <div class="post-list">
    {posts.map(post => (
      <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="post-card">
        <div class="post-meta">
          <span class="post-date">{post.data.date}</span>
          {post.data.tags && (
            <div class="post-tags">
              {post.data.tags.slice(0, 3).map(tag => (
                <span class="tag">#{tag}</span>
              ))}
            </div>
          )}
        </div>
        <h2 class="post-title">{post.data.title.replace(/^\d{4}-\d{2}-\d{2}\s+/, '')}</h2>
        {post.data.description && (
          <p class="post-desc">{post.data.description}</p>
        )}
        <span class="read-more">閱讀全文 →</span>
      </a>
    ))}
  </div>
</Layout>

<style>
  .page-header { margin-bottom: 2.5rem; }
  .subtitle { color: #64748b; margin-top: 0.3rem; }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .post-card {
    display: block;
    background: #111827;
    border: 1px solid #1e2535;
    border-radius: 12px;
    padding: 1.5rem 2rem;
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s;
  }
  .post-card:hover {
    border-color: #38bdf8;
    transform: translateY(-2px);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }
  .post-date {
    font-size: 0.8rem;
    color: #475569;
  }
  .post-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .tag {
    font-size: 0.72rem;
    color: #818cf8;
    background: #1a1a2e;
    padding: 0.15rem 0.5rem;
    border-radius: 99px;
  }

  .post-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: #e2e8f0;
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }

  .post-desc {
    font-size: 0.88rem;
    color: #64748b;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .read-more {
    font-size: 0.82rem;
    color: #38bdf8;
    font-weight: 600;
  }
</style>
