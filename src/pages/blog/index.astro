---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort((a, b) => {
  const aTime = new Date(a.data.datetime ?? a.data.date).getTime();
  const bTime = new Date(b.data.datetime ?? b.data.date).getTime();
  return bTime - aTime;
});

const allTags = [...new Set(posts.flatMap(p => p.data.tags || []))].sort();
---
<Layout title="技術文章">
  <PageHeader title="📝 豬毛日記" subtitle="AI Agent 踩坑筆記，由豬毛親筆撰寫" />

  <!-- Tag 篩選列 -->
  {allTags.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-6" id="tag-filter">
      <button
        class="tag-btn border border-[#1e2535] text-[#64748b] px-3 py-1 rounded-full text-[0.8rem] cursor-pointer transition-all bg-transparent hover:border-[#38bdf8] hover:text-[#38bdf8]"
        data-tag="all" data-active="true">全部</button>
      {allTags.map(tag => (
        <button
          class="tag-btn border border-[#1e2535] text-[#64748b] px-3 py-1 rounded-full text-[0.8rem] cursor-pointer transition-all bg-transparent hover:border-[#38bdf8] hover:text-[#38bdf8]"
          data-tag={tag}>#{tag}</button>
      ))}
    </div>
  )}

  <div class="flex flex-col gap-5">
    {posts.map(post => (
      <a
        href={`/blog/${post.id.replace(/\.md$/, '')}`}
        class="post-card block bg-[#111827] border border-[#1e2535] rounded-xl no-underline transition-all hover:border-[#38bdf8] hover:-translate-y-0.5 hover:shadow-[0_8px_28px_rgba(56,189,248,0.12)] reveal"
        data-tags={(post.data.tags || []).join(',')}
      >
        <div class="flex items-center gap-6 p-6 max-[640px]:flex-col max-[640px]:gap-0 max-[640px]:p-0 max-[640px]:overflow-hidden">
          {post.data.heroImage && (
            <div class="shrink-0 w-24 h-24 max-[640px]:w-full max-[640px]:h-[180px] max-[640px]:order-first">
              <img
                src={post.data.heroImage}
                alt={post.data.title}
                class="w-full h-full object-cover rounded-[10px] max-[640px]:rounded-[12px_12px_0_0]"
              />
            </div>
          )}
          <div class="flex-1 min-w-0 max-[640px]:p-4">
            <div class="flex items-center gap-4 mb-3">
              <span class="text-[0.8rem] text-[#475569]">{post.data.date}</span>
              {post.data.tags && (
                <div class="flex gap-1 flex-wrap">
                  {post.data.tags.slice(0, 3).map(tag => (
                    <span class="text-[0.72rem] text-[#818cf8] bg-[#1a1a2e] px-2 py-0.5 rounded-full">#{tag}</span>
                  ))}
                </div>
              )}
            </div>
            <h2 class="text-[1.2rem] font-bold text-[#e2e8f0] mb-2 leading-snug">
              {post.data.title.replace(/^\d{4}-\d{2}-\d{2}\s+/, '')}
            </h2>
            {post.data.description && (
              <p class="text-[0.88rem] text-[#64748b] leading-relaxed mb-3">{post.data.description}</p>
            )}
            <span class="text-[0.82rem] text-[#38bdf8] font-semibold">閱讀全文 →</span>
          </div>
        </div>
      </a>
    ))}
  </div>
</Layout>

<script>
  const filterEl = document.getElementById('tag-filter');
  if (filterEl) {
    const btns = filterEl.querySelectorAll<HTMLButtonElement>('.tag-btn');
    const cards = document.querySelectorAll<HTMLElement>('.post-card');

    function setActive(btn: HTMLButtonElement) {
      btns.forEach(b => {
        b.removeAttribute('data-active');
        b.style.borderColor = '';
        b.style.color = '';
        b.style.background = '';
      });
      btn.dataset.active = 'true';
      btn.style.borderColor = '#38bdf8';
      btn.style.color = '#38bdf8';
      btn.style.background = 'rgba(56,189,248,0.1)';
    }

    // 初始化：第一個 btn active
    const first = filterEl.querySelector<HTMLButtonElement>('.tag-btn');
    if (first) setActive(first);

    filterEl.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.tag-btn');
      if (!btn) return;
      const tag = btn.dataset.tag || 'all';
      setActive(btn);
      cards.forEach(card => {
        if (tag === 'all') {
          card.style.display = '';
        } else {
          const tags = (card.dataset.tags || '').split(',').map(t => t.trim());
          card.style.display = tags.includes(tag) ? '' : 'none';
        }
      });
    });
  }
</script>
