---
import Layout from '../layouts/Layout.astro'
import PageHeader from '../components/PageHeader.astro'
import StatCard from '../components/StatCard.astro'
import MapSection from '../components/MapSection.astro'
import type { Dive } from '../types/dive'
import divesRaw from '../data/dives.json'

const dives = divesRaw as Dive[]
const totalDives = dives.length
const maxDepth = Math.max(...dives.map(d => d.max_depth || 0))
const maxDepthDive = dives.find(d => d.max_depth === maxDepth)
const totalMinutes = dives.reduce((s, d) => s + (d.bottom_time || 0), 0)
const avgDepth = (dives.reduce((s,d) => s+(d.avg_depth||0),0)/totalDives).toFixed(1)
const divesWithGPS = dives.filter(d => d.lat && d.lon)
const divesWithProfile = dives.filter(d => d.garmin_id)

// 深度分布資料（給圖表用）
const depthBuckets = { '10-15m': 0, '15-20m': 0, '20-25m': 0, '25-30m': 0, '30m+': 0 }
for (const d of dives) {
  const depth = d.max_depth || 0
  if (depth < 15) depthBuckets['10-15m']++
  else if (depth < 20) depthBuckets['15-20m']++
  else if (depth < 25) depthBuckets['20-25m']++
  else if (depth < 30) depthBuckets['25-30m']++
  else depthBuckets['30m+']++
}
const depthChartData = {
  labels: Object.keys(depthBuckets),
  values: Object.values(depthBuckets),
}

// 月份活動資料（給圖表用）
const monthMap: Record<string, number> = {}
for (const d of dives) {
  const ym = d.date.slice(0, 7); // "2024-04"
  monthMap[ym] = (monthMap[ym] || 0) + 1
}
const sortedMonths = Object.keys(monthMap).sort()
const monthChartData = {
  labels: sortedMonths,
  values: sortedMonths.map(m => monthMap[m]),
}

// PB 牆資料
const maxBottomTime = Math.max(...dives.map(d => d.bottom_time || 0))

// 最多潛水月份（按月份數字，不分年）
const calMonthCount: Record<string, number> = {}
for (const d of dives) {
  const m = d.date.slice(5, 7); // "04"
  calMonthCount[m] = (calMonthCount[m] || 0) + 1
}
const busiestMonthEntry = Object.entries(calMonthCount).sort((a, b) => b[1] - a[1])[0]
const monthNames = ['1月','2月','3月','4月','5月','6月','7月','8月','9月','10月','11月','12月']
const busiestMonthName = monthNames[parseInt(busiestMonthEntry[0]) - 1]
const busiestMonthCount = busiestMonthEntry[1]

// 年度比較資料
const yearStatsMap: Record<string, { count: number, minutes: number }> = {}
for (const d of dives) {
  const year = d.date.slice(0, 4)
  if (!yearStatsMap[year]) yearStatsMap[year] = { count: 0, minutes: 0 }
  yearStatsMap[year].count++
  yearStatsMap[year].minutes += d.bottom_time || 0
}
const diveYearData = {
  labels: ['2024', '2025', '2026'],
  counts: ['2024', '2025', '2026'].map(y => yearStatsMap[y]?.count || 0),
  hours: ['2024', '2025', '2026'].map(y => parseFloat(((yearStatsMap[y]?.minutes || 0) / 60).toFixed(1))),
}
---
<Layout title="潛水紀錄" description={`${totalDives} 次潛水 · 最深 ${maxDepth.toFixed(1)}m · 水下 ${Math.floor(totalMinutes/60)} 小時`} ogImage="/og/dives.png">
  <PageHeader title="🤿 潛水紀錄" subtitle="從 2024 年開始的每一支" />

  <!-- 統計卡片 -->
  <div class="grid grid-cols-4 max-md:grid-cols-2 gap-4 mb-10">
    <StatCard value={totalDives} label="總潛水次數" target={totalDives} delay={1} />
    <StatCard value={`${maxDepth.toFixed(1)}m`} label="最大深度" sub={maxDepthDive?.location} target={maxDepth} decimals={1} suffix="m" delay={2} />
    <StatCard value={`${Math.floor(totalMinutes/60)}h ${Math.round(totalMinutes%60)}m`} label="總水下時間" target={Math.floor(totalMinutes/60)} suffix={`h ${Math.round(totalMinutes%60)}m`} delay={3} />
    <StatCard value={`${avgDepth}m`} label="平均深度" target={parseFloat(avgDepth)} decimals={1} suffix="m" delay={4} />
  </div>

  <!-- PB 牆 -->
  <div class="mb-12">
    <h2 class="mb-4">🏆 個人紀錄 PB</h2>
    <div class="grid grid-cols-3 max-md:grid-cols-1 gap-4">
      <div class="bg-surface border-border rounded-xl text-center relative py-8 px-6 anim-fade-up delay-1 hover:shadow-[-4px_6px_0px_#dad4c8] transition-all duration-250 hover:-translate-y-1 pb-card">
        <div class="text-2xl mb-2">🏆</div>
        <div class="text-xs text-subtle uppercase tracking-[1px] mb-2">最大深度</div>
        <div class="text-[2.4rem] leading-none font-extrabold text-[#3bd3fd]">33.9<span class="text-base font-semibold ml-[0.2rem]">m</span></div>
        <div class="text-[0.8rem] text-subtle mt-2">Koror, Belau</div>
      </div>
      <div class="bg-surface border-border rounded-xl text-center relative py-8 px-6 anim-fade-up delay-2 hover:shadow-[-4px_6px_0px_#dad4c8] transition-all duration-250 hover:-translate-y-1 pb-card">
        <div class="text-2xl mb-2">🏆</div>
        <div class="text-xs text-subtle uppercase tracking-[1px] mb-2">最長底部時間</div>
        <div class="text-[2.4rem] leading-none font-extrabold text-[#3bd3fd]">{maxBottomTime.toFixed(1)}<span class="text-base font-semibold ml-[0.2rem]">min</span></div>
        <div class="text-[0.8rem] text-subtle mt-2">單次最長水下停留</div>
      </div>
      <div class="bg-surface border-border rounded-xl text-center relative py-8 px-6 anim-fade-up delay-3 hover:shadow-[-4px_6px_0px_#dad4c8] transition-all duration-250 hover:-translate-y-1 pb-card">
        <div class="text-2xl mb-2">🏆</div>
        <div class="text-xs text-subtle uppercase tracking-[1px] mb-2">最多潛水月份</div>
        <div class="text-[2.4rem] leading-none font-extrabold text-[#3bd3fd]">{busiestMonthName}</div>
        <div class="text-[0.8rem] text-subtle mt-2">共 {busiestMonthCount} 支潛水</div>
      </div>
    </div>
  </div>

  <!-- 年度比較 -->
  <div class="mb-12">
    <h2>📊 年度比較</h2>
    <div class="bg-surface border border-border rounded-xl pt-5 px-6 pb-6">
      <div class="text-[0.8rem] text-subtle uppercase tracking-[1px] mb-3">潛水次數 vs 總小時數</div>
      <div class="relative h-55">
        <canvas data-chart="year-compare"></canvas>
      </div>
    </div>
  </div>

  <!-- 地圖 -->
  <MapSection id="dive-map" title="潛點地圖" />

  <!-- 數據圖表 -->
  <div class="mb-12">
    <h2>數據圖表</h2>
    <div class="grid grid-cols-2 max-md:grid-cols-1 gap-4">
      <div class="bg-surface border border-border rounded-xl pt-5 px-6 pb-6">
        <div class="text-[0.8rem] text-subtle uppercase tracking-[1px] mb-3">深度分布</div>
        <div class="relative h-55">
          <canvas data-chart="depth-dist"></canvas>
        </div>
      </div>
      <div class="bg-surface border border-border rounded-xl pt-5 px-6 pb-6">
        <div class="text-[0.8rem] text-subtle uppercase tracking-[1px] mb-3">每月潛水次數</div>
        <div class="relative h-55">
          <canvas data-chart="monthly"></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- 潛水列表（含內嵌深度曲線） -->
  <div class="mb-12">
    <h2>所有紀錄</h2>
    <!-- 篩選列 -->
    <div class="flex items-center gap-3 max-md:gap-2 mb-4 flex-wrap">
      <input
        type="text"
        data-ref="search"
        class="flex-1 min-w-45 py-2 px-[0.85rem] bg-surface border-border rounded-lg text-muted text-sm outline-none transition-[border-color] duration-200 focus:border-[#3bd3fd] placeholder:text-subtle"
        placeholder="搜尋地點關鍵字..."
        autocomplete="off"
      />
      <select data-ref="year-select" class="py-2 px-[0.85rem] bg-surface border-border rounded-lg text-muted text-sm cursor-pointer outline-none transition-[border-color] duration-200 focus:border-[#3bd3fd]">
        <option value="">全部年份</option>
        <option value="2024">2024</option>
        <option value="2025">2025</option>
        <option value="2026">2026</option>
      </select>
      <span data-ref="count" class="text-[0.8rem] text-faint whitespace-nowrap ml-auto max-md:ml-0">顯示 {totalDives} / {totalDives} 筆</span>
    </div>
    <div class="flex flex-col gap-[0.6rem]">
      {dives.slice().reverse().map(d => (
        <div class="dive-row bg-surface border-border rounded-xl p-0 overflow-hidden transition-[border-color,transform,box-shadow] duration-[250ms] hover:border-[#3bd3fd] hover:-translate-y-1 hover:shadow-[-3px_5px_0px_#3bd3fd] reveal">
          <div class="dive-main flex items-center gap-4 max-md:gap-2 px-6 py-4 max-md:px-4 max-md:py-3 flex-wrap">
            <div class="text-[0.8rem] text-faint min-w-10 font-bold">#{d.num}</div>
            <div class="flex-1 min-w-0">
              <div class="dive-location font-semibold text-[0.95rem]">{d.location || 'Unknown'}</div>
              <div class="dive-date text-[0.8rem] text-subtle mt-[0.1rem]">{d.date}</div>
            </div>
            <div class="flex gap-[0.4rem] flex-wrap max-md:w-full">
              <span class="py-[0.2rem] px-[0.6rem] rounded-full text-xs font-semibold bg-pill-cyan text-accent">▼ {d.max_depth}m</span>
              <span class="py-[0.2rem] px-[0.6rem] rounded-full text-xs font-semibold bg-tag-bg text-indigo">⏱ {d.bottom_time ? Math.floor(d.bottom_time)+'m' : '-'}</span>
              {d.water_temp && <span class="py-[0.2rem] px-[0.6rem] rounded-full text-xs font-semibold bg-pill-green text-green">🌡 {d.water_temp}°C</span>}
              {d.gas && d.gas !== 'Air' && <span class="py-[0.2rem] px-[0.6rem] rounded-full text-xs font-semibold bg-pill-red text-red">{d.gas}</span>}
            </div>
            {d.garmin_id && (
              <button class="chart-toggle group flex items-center gap-[0.3rem] py-[0.3rem] px-[0.7rem] bg-transparent border border-border rounded-md text-accent text-[0.78rem] cursor-pointer transition-all duration-200 whitespace-nowrap hover:border-accent hover:bg-accent/5" data-dive={d.num} aria-expanded="false">
                <span class="inline-block transition-transform duration-200 text-[0.6rem] group-aria-[expanded=true]:rotate-90">▶</span>
                <span>深度曲線</span>
              </button>
            )}
          </div>
          {d.garmin_id && (
            <div class="border-t border-border pt-4 px-6 pb-6 max-md:pt-3 max-md:px-3 max-md:pb-4" id={`chart-panel-${d.num}`} hidden>
              <div class="relative h-50 max-md:h-45">
                <canvas id={`chart-${d.num}`}></canvas>
              </div>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</Layout>

<!-- 傳資料給前端 JS（is:inline 確保同步執行，define:vars 之後立刻可取得） -->
<script define:vars={{ divesWithGPS, divesWithProfile, depthChartData, monthChartData, totalDives, diveYearData }} is:inline>
  window.__DIVES_GPS__ = divesWithGPS
  window.__DIVES_PROFILE__ = divesWithProfile
  window.__DEPTH_CHART_DATA__ = depthChartData
  window.__MONTH_CHART_DATA__ = monthChartData
  window.__TOTAL_DIVES__ = totalDives
  window.__DIVE_YEAR_DATA__ = diveYearData
</script>
<script>
  import '../scripts/dive-app.ts'
  import '../scripts/dives-ui.ts'
  import '../scripts/count-up.ts'
</script>


<!-- Leaflet CSS -->

