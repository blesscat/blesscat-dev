---
import Layout from '../layouts/Layout.astro';
import type { Dive } from '../types/dive';
import divesRaw from '../data/dives.json';

const dives = divesRaw as Dive[];
const totalDives = dives.length;
const maxDepth = Math.max(...dives.map(d => d.max_depth || 0));
const maxDepthDive = dives.find(d => d.max_depth === maxDepth);
const totalMinutes = dives.reduce((s, d) => s + (d.bottom_time || 0), 0);
const avgDepth = (dives.reduce((s,d) => s+(d.avg_depth||0),0)/totalDives).toFixed(1);
const divesWithGPS = dives.filter(d => d.lat && d.lon);
const divesWithProfile = dives.filter(d => d.garmin_id);

// 深度分布資料（給圖表用）
const depthBuckets = { '10-15m': 0, '15-20m': 0, '20-25m': 0, '25-30m': 0, '30m+': 0 };
for (const d of dives) {
  const depth = d.max_depth || 0;
  if (depth < 15) depthBuckets['10-15m']++;
  else if (depth < 20) depthBuckets['15-20m']++;
  else if (depth < 25) depthBuckets['20-25m']++;
  else if (depth < 30) depthBuckets['25-30m']++;
  else depthBuckets['30m+']++;
}
const depthChartData = {
  labels: Object.keys(depthBuckets),
  values: Object.values(depthBuckets),
};

// 月份活動資料（給圖表用）
const monthMap: Record<string, number> = {};
for (const d of dives) {
  const ym = d.date.slice(0, 7); // "2024-04"
  monthMap[ym] = (monthMap[ym] || 0) + 1;
}
const sortedMonths = Object.keys(monthMap).sort();
const monthChartData = {
  labels: sortedMonths,
  values: sortedMonths.map(m => monthMap[m]),
};

// PB 牆資料
const maxBottomTime = Math.max(...dives.map(d => d.bottom_time || 0));

// 最多潛水月份（按月份數字，不分年）
const calMonthCount: Record<string, number> = {};
for (const d of dives) {
  const m = d.date.slice(5, 7); // "04"
  calMonthCount[m] = (calMonthCount[m] || 0) + 1;
}
const busiestMonthEntry = Object.entries(calMonthCount).sort((a, b) => b[1] - a[1])[0];
const monthNames = ['1月','2月','3月','4月','5月','6月','7月','8月','9月','10月','11月','12月'];
const busiestMonthName = monthNames[parseInt(busiestMonthEntry[0]) - 1];
const busiestMonthCount = busiestMonthEntry[1];

// 年度比較資料
const yearStatsMap: Record<string, { count: number, minutes: number }> = {};
for (const d of dives) {
  const year = d.date.slice(0, 4);
  if (!yearStatsMap[year]) yearStatsMap[year] = { count: 0, minutes: 0 };
  yearStatsMap[year].count++;
  yearStatsMap[year].minutes += d.bottom_time || 0;
}
const diveYearData = {
  labels: ['2024', '2025', '2026'],
  counts: ['2024', '2025', '2026'].map(y => yearStatsMap[y]?.count || 0),
  hours: ['2024', '2025', '2026'].map(y => parseFloat(((yearStatsMap[y]?.minutes || 0) / 60).toFixed(1))),
};
---
<Layout title="潛水紀錄" description={`${totalDives} 次潛水 · 最深 ${maxDepth.toFixed(1)}m · 水下 ${Math.floor(totalMinutes/60)} 小時`} ogImage="/og/dives.png">
  <div class="page-header">
    <h1>🤿 潛水紀錄</h1>
    <p class="subtitle">從 2024 年開始的每一支</p>
  </div>

  <!-- 統計卡片 -->
  <div class="stats-grid">
    <div class="card stat-card anim-fade-up delay-1">
      <div class="stat-num count-up" data-target={totalDives} data-decimals="0">{totalDives}</div>
      <div class="stat-label">總潛水次數</div>
    </div>
    <div class="card stat-card anim-fade-up delay-2">
      <div class="stat-num count-up" data-target={maxDepth} data-decimals="1" data-suffix="m">{maxDepth.toFixed(1)}m</div>
      <div class="stat-label">最大深度</div>
      <div class="stat-sub">{maxDepthDive?.location}</div>
    </div>
    <div class="card stat-card anim-fade-up delay-3">
      <div class="stat-num count-up" data-target={Math.floor(totalMinutes/60)} data-decimals="0" data-suffix={`h ${Math.round(totalMinutes%60)}m`}>{Math.floor(totalMinutes/60)}h {Math.round(totalMinutes%60)}m</div>
      <div class="stat-label">總水下時間</div>
    </div>
    <div class="card stat-card anim-fade-up delay-4">
      <div class="stat-num count-up" data-target={parseFloat(avgDepth)} data-decimals="1" data-suffix="m">{avgDepth}m</div>
      <div class="stat-label">平均深度</div>
    </div>
  </div>

  <!-- PB 牆 -->
  <div class="section pb-section">
    <h2>🏆 個人紀錄 PB</h2>
    <div class="pb-grid">
      <div class="card pb-card anim-fade-up delay-1">
        <div class="pb-badge">🏆</div>
        <div class="pb-label">最大深度</div>
        <div class="stat-num">33.9<span class="pb-unit">m</span></div>
        <div class="pb-sub">Koror, Belau</div>
      </div>
      <div class="card pb-card anim-fade-up delay-2">
        <div class="pb-badge">🏆</div>
        <div class="pb-label">最長底部時間</div>
        <div class="stat-num">{maxBottomTime.toFixed(1)}<span class="pb-unit">min</span></div>
        <div class="pb-sub">單次最長水下停留</div>
      </div>
      <div class="card pb-card anim-fade-up delay-3">
        <div class="pb-badge">🏆</div>
        <div class="pb-label">最多潛水月份</div>
        <div class="stat-num">{busiestMonthName}</div>
        <div class="pb-sub">共 {busiestMonthCount} 支潛水</div>
      </div>
    </div>
  </div>

  <!-- 年度比較 -->
  <div class="section">
    <h2>📊 年度比較</h2>
    <div class="card chart-card-stat">
      <div class="chart-section-title">潛水次數 vs 總小時數</div>
      <div style="position:relative;height:220px;">
        <canvas id="year-compare-chart"></canvas>
      </div>
    </div>
  </div>

  <!-- 地圖 -->
  <div class="section">
    <h2>潛點地圖</h2>
    <div id="dive-map" class="map-container"></div>
  </div>

  <!-- 數據圖表 -->
  <div class="section">
    <h2>數據圖表</h2>
    <div class="charts-grid">
      <div class="card chart-card-stat">
        <div class="chart-section-title">深度分布</div>
        <div class="chart-wrapper-stat">
          <canvas id="depth-dist-chart"></canvas>
        </div>
      </div>
      <div class="card chart-card-stat">
        <div class="chart-section-title">每月潛水次數</div>
        <div class="chart-wrapper-stat">
          <canvas id="monthly-chart"></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- 潛水列表（含內嵌深度曲線） -->
  <div class="section">
    <h2>所有紀錄</h2>
    <!-- 篩選列 -->
    <div class="filter-bar">
      <input
        type="text"
        id="dive-search"
        class="filter-input"
        placeholder="搜尋地點關鍵字..."
        autocomplete="off"
      />
      <select id="year-filter" class="filter-select">
        <option value="">全部年份</option>
        <option value="2024">2024</option>
        <option value="2025">2025</option>
        <option value="2026">2026</option>
      </select>
      <span id="filter-count" class="filter-count">顯示 {totalDives} / {totalDives} 筆</span>
    </div>
    <div class="dive-list">
      {dives.slice().reverse().map(d => (
        <div class="dive-row card reveal">
          <div class="dive-main">
            <div class="dive-num">#{d.num}</div>
            <div class="dive-info">
              <div class="dive-location">{d.location || 'Unknown'}</div>
              <div class="dive-date">{d.date}</div>
            </div>
            <div class="dive-stats">
              <span class="pill depth">▼ {d.max_depth}m</span>
              <span class="pill time">⏱ {d.bottom_time ? Math.floor(d.bottom_time)+'m' : '-'}</span>
              {d.water_temp && <span class="pill temp">🌡 {d.water_temp}°C</span>}
              {d.gas && d.gas !== 'Air' && <span class="pill gas">{d.gas}</span>}
            </div>
            {d.garmin_id && (
              <button class="chart-toggle" data-dive={d.num} aria-expanded="false">
                <span class="toggle-icon">▶</span>
                <span class="toggle-label">深度曲線</span>
              </button>
            )}
          </div>
          {d.garmin_id && (
            <div class="dive-chart-panel" id={`chart-panel-${d.num}`} hidden>
              <div class="chart-wrapper">
                <canvas id={`chart-${d.num}`}></canvas>
              </div>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</Layout>

<!-- 傳資料給前端 JS -->
<script define:vars={{ divesWithGPS, divesWithProfile, depthChartData, monthChartData, totalDives, diveYearData }}>
  window.__DIVES_GPS__ = divesWithGPS;
  window.__DIVES_PROFILE__ = divesWithProfile;
  window.__DEPTH_CHART_DATA__ = depthChartData;
  window.__MONTH_CHART_DATA__ = monthChartData;
  window.__TOTAL_DIVES__ = totalDives;
  window.__DIVE_YEAR_DATA__ = diveYearData;
</script>
<script>
  import '../scripts/dive-app.ts';
</script>
<script>
  // 數據圖表：深度分布 + 月份活動
  (function initStatCharts() {
    const CHART_CDN = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js';

    function loadChartJS(cb: () => void) {
      if ((window as any).Chart) { cb(); return; }
      const s = document.createElement('script');
      s.src = CHART_CDN;
      s.onload = cb;
      document.head.appendChild(s);
    }

    function buildCharts() {
      const depthData = (window as any).__DEPTH_CHART_DATA__;
      const monthData = (window as any).__MONTH_CHART_DATA__;
      const Chart = (window as any).Chart;
      if (!depthData || !monthData || !Chart) return;

      // 深度分布圖
      const depthCanvas = document.getElementById('depth-dist-chart') as HTMLCanvasElement;
      if (depthCanvas) {
        const colors = depthData.labels.map((l: string) =>
          l === '30m+' ? '#f87171' : '#38bdf8'
        );
        new Chart(depthCanvas.getContext('2d'), {
          type: 'bar',
          data: {
            labels: depthData.labels,
            datasets: [{
              data: depthData.values,
              backgroundColor: colors,
              borderRadius: 6,
              borderSkipped: false,
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { display: false },
              tooltip: {
                callbacks: {
                  label: (ctx: any) => ` ${ctx.parsed.y} 次`
                }
              }
            },
            scales: {
              x: {
                grid: { color: '#1e2535' },
                ticks: { color: '#94a3b8', font: { size: 12 } }
              },
              y: {
                grid: { color: '#1e2535' },
                ticks: { color: '#94a3b8', stepSize: 1 },
                beginAtZero: true,
              }
            }
          }
        });
      }

      // 月份活動圖
      const monthCanvas = document.getElementById('monthly-chart') as HTMLCanvasElement;
      if (monthCanvas) {
        const yearColors: Record<string, string> = {
          '2024': '#38bdf8',
          '2025': '#818cf8',
          '2026': '#4ade80',
        };
        const bgColors = monthData.labels.map((ym: string) => yearColors[ym.slice(0,4)] || '#38bdf8');
        new Chart(monthCanvas.getContext('2d'), {
          type: 'bar',
          data: {
            labels: monthData.labels,
            datasets: [{
              data: monthData.values,
              backgroundColor: bgColors,
              borderRadius: 6,
              borderSkipped: false,
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { display: false },
              tooltip: {
                callbacks: {
                  label: (ctx: any) => ` ${ctx.parsed.y} 次`
                }
              }
            },
            scales: {
              x: {
                grid: { color: '#1e2535' },
                ticks: { color: '#94a3b8', font: { size: 11 }, maxRotation: 45 }
              },
              y: {
                grid: { color: '#1e2535' },
                ticks: { color: '#94a3b8', stepSize: 1 },
                beginAtZero: true,
              }
            }
          }
        });
      }
    }

    // 使用 IntersectionObserver 懶載入
    const section = document.querySelector('#depth-dist-chart');
    if (!section) return;
    const io = new IntersectionObserver((entries) => {
      if (entries.some(e => e.isIntersecting)) {
        io.disconnect();
        loadChartJS(buildCharts);
      }
    }, { rootMargin: '200px' });
    io.observe(section);
  })();

  // 年度比較圖
  (function initYearChart() {
    const CHART_CDN = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js';
    function loadChartJS(cb: () => void) {
      if ((window as any).Chart) { cb(); return; }
      const s = document.createElement('script');
      s.src = CHART_CDN;
      s.onload = cb;
      document.head.appendChild(s);
    }
    function buildYearChart() {
      const yearData = (window as any).__DIVE_YEAR_DATA__;
      const Chart = (window as any).Chart;
      if (!yearData || !Chart) return;
      const canvas = document.getElementById('year-compare-chart') as HTMLCanvasElement;
      if (!canvas) return;
      new Chart(canvas.getContext('2d'), {
        type: 'bar',
        data: {
          labels: yearData.labels,
          datasets: [
            {
              label: '潛水次數',
              data: yearData.counts,
              backgroundColor: ['#38bdf8', '#818cf8', '#4ade80'],
              borderRadius: 6,
              borderSkipped: false,
            },
            {
              label: '總小時數',
              data: yearData.hours,
              backgroundColor: ['rgba(56,189,248,0.4)', 'rgba(129,140,248,0.4)', 'rgba(74,222,128,0.4)'],
              borderRadius: 6,
              borderSkipped: false,
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: true, labels: { color: '#94a3b8', font: { size: 12 } } },
            tooltip: {
              callbacks: {
                label: (ctx: any) => ctx.datasetIndex === 0
                  ? ` ${ctx.parsed.y} 次`
                  : ` ${ctx.parsed.y} 小時`
              }
            }
          },
          scales: {
            x: { grid: { color: '#1e2535' }, ticks: { color: '#94a3b8', font: { size: 13 } } },
            y: { grid: { color: '#1e2535' }, ticks: { color: '#94a3b8' }, beginAtZero: true }
          }
        }
      });
    }
    const canvas = document.querySelector('#year-compare-chart');
    if (!canvas) return;
    const io = new IntersectionObserver((entries) => {
      if (entries.some(e => e.isIntersecting)) {
        io.disconnect();
        loadChartJS(buildYearChart);
      }
    }, { rootMargin: '200px' });
    io.observe(canvas);
  })();

  // 搜尋 + 篩選功能
  (function initFilter() {
    const searchInput = document.getElementById('dive-search') as HTMLInputElement;
    const yearSelect = document.getElementById('year-filter') as HTMLSelectElement;
    const countEl = document.getElementById('filter-count') as HTMLSpanElement;
    const rows = document.querySelectorAll<HTMLElement>('.dive-row');
    const total = (window as any).__TOTAL_DIVES__ || rows.length;

    function applyFilter() {
      const keyword = searchInput.value.trim().toLowerCase();
      const year = yearSelect.value;
      let shown = 0;

      rows.forEach(row => {
        const locationEl = row.querySelector('.dive-location');
        const dateEl = row.querySelector('.dive-date');
        const location = locationEl?.textContent?.toLowerCase() || '';
        const date = dateEl?.textContent || '';
        const rowYear = date.slice(0, 4);

        const matchKeyword = !keyword || location.includes(keyword);
        const matchYear = !year || rowYear === year;

        if (matchKeyword && matchYear) {
          row.style.display = '';
          shown++;
        } else {
          row.style.display = 'none';
        }
      });

      countEl.textContent = `顯示 ${shown} / ${total} 筆`;
    }

    searchInput?.addEventListener('input', applyFilter);
    yearSelect?.addEventListener('change', applyFilter);
  })();
</script>
<script>
  // Count-up animation for stat cards
  function animateCountUp(el: HTMLElement) {
    const target = parseFloat(el.dataset.target || '0');
    const decimals = parseInt(el.dataset.decimals || '0');
    const suffix = el.dataset.suffix || '';
    const duration = 1100;
    const start = performance.now();
    function tick(now: number) {
      const progress = Math.min((now - start) / duration, 1);
      const ease = 1 - Math.pow(1 - progress, 3);
      el.textContent = (target * ease).toFixed(decimals) + suffix;
      if (progress < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }
  const counters = document.querySelectorAll<HTMLElement>('.count-up');
  const io = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        animateCountUp(entry.target as HTMLElement);
        io.unobserve(entry.target);
      }
    });
  }, { threshold: 0.4 });
  counters.forEach(el => io.observe(el));
</script>

<!-- Leaflet CSS -->
