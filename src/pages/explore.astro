---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import divesRaw from '../data/dives.json';
import skiRaw from '../data/ski.json';

const dives = divesRaw as any[];
const ski = skiRaw as any[];

const allYears = [
  ...dives.map(d => parseInt(d.date.slice(0, 4))),
  ...ski.map(d => parseInt(d.date.slice(0, 4))),
];
const yearMin = Math.min(...allYears);
const yearMax = Math.max(...allYears);
---

<Layout title="探索地圖" description="潛水潛點 × 滑雪雪場，橫跨多個國家的探索足跡" ogImage="/og/explore.png">
  <PageHeader title="🌏 探索地圖" subtitle="潛水潛點 × 滑雪雪場，點擊標記查看詳情" />

  <!-- 統計 mini bar -->
  <div id="explore-stats" class="flex items-center gap-3 bg-[#111827] border border-[#1e2535] rounded-[10px] px-[1.2rem] py-[0.6rem] mb-4 text-[0.82rem] flex-wrap anim-fade-up delay-2">
    <span class="stat-item">載入中⋯</span>
  </div>

  <!-- 控制列 -->
  <div class="flex items-center gap-4 mb-3 flex-wrap anim-fade-up delay-3 max-[480px]:gap-[0.6rem]">
    <div class="flex gap-2">
      <button id="toggle-dive" class="toggle-btn dive flex items-center gap-[0.4rem] py-[0.45rem] px-[0.9rem] rounded-full text-[0.8rem] font-semibold cursor-pointer border transition-all bg-[rgba(56,189,248,0.12)] border-[#38bdf8] text-[#38bdf8] max-[480px]:py-[0.4rem] max-[480px]:px-[0.7rem] max-[480px]:text-[0.75rem]">
        <span class="dot dive-dot w-2 h-2 rounded-full inline-block bg-[#38bdf8]"></span>🤿 潛水
      </button>
      <button id="toggle-ski" class="toggle-btn ski flex items-center gap-[0.4rem] py-[0.45rem] px-[0.9rem] rounded-full text-[0.8rem] font-semibold cursor-pointer border transition-all bg-[rgba(129,140,248,0.12)] border-[#818cf8] text-[#818cf8] max-[480px]:py-[0.4rem] max-[480px]:px-[0.7rem] max-[480px]:text-[0.75rem]">
        <span class="dot ski-dot w-2 h-2 rounded-full inline-block bg-[#818cf8]"></span>⛷️ 滑雪
      </button>
    </div>

    <div id="year-control" class="flex items-center gap-[0.6rem] ml-auto max-[768px]:ml-0">
      <span class="text-[0.75rem] text-[#475569] whitespace-nowrap">年份</span>
      <input id="year-slider" type="range"
        min={yearMin} max={yearMax} value={yearMax}
        class="year-slider appearance-none w-[140px] h-1 bg-[#1e2535] rounded-sm outline-none cursor-pointer max-[768px]:w-[100px]"
      />
      <span id="year-label" class="text-[0.75rem] text-[#38bdf8] bg-[rgba(56,189,248,0.1)] border border-[rgba(56,189,248,0.2)] rounded-[6px] px-2 py-[0.15rem] whitespace-nowrap">{yearMin} – {yearMax}</span>
    </div>
  </div>

  <!-- 地圖 + 側邊資訊卡 -->
  <div class="relative rounded-2xl overflow-hidden border border-[#1e2535] mb-8 anim-fade-up delay-4">
    <div id="explore-map" class="h-[580px] w-full bg-[#090d18] max-[768px]:h-[420px]"></div>
    <div id="info-card" class="info-card absolute top-0 right-[-360px] w-[340px] h-full bg-[#0d1220ee] backdrop-blur-[12px] border-l border-[#1e2535] overflow-y-auto transition-[right] duration-300 [transition-timing-function:cubic-bezier(0.22,1,0.36,1)] z-[1000] p-0 max-[768px]:top-auto max-[768px]:bottom-[-100%] max-[768px]:right-0 max-[768px]:w-full max-[768px]:h-[60%] max-[768px]:border-l-0 max-[768px]:border-t max-[768px]:border-t-[#1e2535] max-[768px]:rounded-t-2xl max-[768px]:[transition-property:bottom] max-[768px]:[transition-duration:300ms] max-[768px]:[transition-timing-function:cubic-bezier(0.22,1,0.36,1)]">
      <!-- 動態填入 -->
    </div>
  </div>
</Layout>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<!-- 傳資料給前端 -->
<script define:vars={{ dives, ski }} is:inline>
  window.__EXPLORE_DIVES__ = dives;
  window.__EXPLORE_SKI__ = ski;
</script>
<script>
  import '../scripts/explore-app.ts';
</script>

<style is:global>
  /* slider thumb — pseudo-element，無法 inline */
  .year-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 14px; height: 14px;
    border-radius: 50%;
    background: #38bdf8;
    cursor: pointer;
    box-shadow: 0 0 6px #38bdf8aa;
  }
</style>
