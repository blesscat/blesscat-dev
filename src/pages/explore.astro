---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import InfoCard from '../components/InfoCard.svelte';
import divesRaw from '../data/dives.json';
import skiRaw from '../data/ski.json';

const dives = divesRaw as any[];
const ski = skiRaw as any[];

const allYears = [
  ...dives.map(d => parseInt(d.date.slice(0, 4))),
  ...ski.map(d => parseInt(d.date.slice(0, 4))),
];
const yearMin = Math.min(...allYears);
const yearMax = Math.max(...allYears);
---

<Layout title="探索地圖" description="潛水潛點 × 滑雪雪場，橫跨多個國家的探索足跡" ogImage="/og/explore.png">
  <PageHeader title="🌏 探索地圖" subtitle="潛水潛點 × 滑雪雪場，點擊標記查看詳情" />

  <!-- 統計 mini bar -->
  <div id="explore-stats" class="flex items-center gap-3 bg-surface border border-border rounded-[10px] px-[1.2rem] py-[0.6rem] mb-4 text-[0.82rem] flex-wrap anim-fade-up delay-2">
    <span class="stat-item">載入中⋯</span>
  </div>

  <!-- 控制列 -->
  <div class="flex items-center gap-4 mb-3 flex-wrap anim-fade-up delay-3 max-[480px]:gap-[0.6rem]">
    <div class="flex gap-2">
      <button id="toggle-dive" class="toggle-btn dive flex items-center gap-[0.4rem] py-[0.45rem] px-[0.9rem] rounded-full text-[0.8rem] font-semibold cursor-pointer border transition-all bg-[rgba(56,189,248,0.12)] border-accent text-accent max-[480px]:py-[0.4rem] max-[480px]:px-[0.7rem] max-[480px]:text-[0.75rem]">
        <span class="dot dive-dot w-2 h-2 rounded-full inline-block bg-accent"></span>🤿 潛水
      </button>
      <button id="toggle-ski" class="toggle-btn ski flex items-center gap-[0.4rem] py-[0.45rem] px-[0.9rem] rounded-full text-[0.8rem] font-semibold cursor-pointer border transition-all bg-[rgba(129,140,248,0.12)] border-indigo text-indigo max-[480px]:py-[0.4rem] max-[480px]:px-[0.7rem] max-[480px]:text-[0.75rem]">
        <span class="dot ski-dot w-2 h-2 rounded-full inline-block bg-indigo"></span>⛷️ 滑雪
      </button>
    </div>

    <div id="year-control" class="flex items-center gap-[0.6rem] ml-auto max-[768px]:ml-0">
      <span class="text-[0.75rem] text-faint whitespace-nowrap">年份</span>
      <input id="year-slider" type="range"
        min={yearMin} max={yearMax} value={yearMax}
        class="year-slider appearance-none w-35 h-1 bg-border rounded-sm outline-none cursor-pointer max-[768px]:w-25"
      />
      <span id="year-label" class="text-[0.75rem] text-accent bg-[rgba(56,189,248,0.1)] border border-[rgba(56,189,248,0.2)] rounded-[6px] px-2 py-[0.15rem] whitespace-nowrap">{yearMin} – {yearMax}</span>
    </div>
  </div>

  <!-- 地圖 + 側邊資訊卡 -->
  <div class="relative rounded-2xl overflow-hidden border border-border mb-8 anim-fade-up delay-4">
    <div id="explore-map" class="h-145 w-full bg-[#090d18] max-[768px]:h-105"></div>
    <InfoCard client:only="svelte" />
  </div>
</Layout>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<!-- 傳資料給前端 -->
<script define:vars={{ dives, ski }} is:inline>
  window.__EXPLORE_DIVES__ = dives;
  window.__EXPLORE_SKI__ = ski;
</script>
<script>
  import '../scripts/explore-app.ts';
</script>

<style is:global>
  /* slider thumb — pseudo-element，無法 inline */
  .year-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 14px; height: 14px;
    border-radius: 50%;
    background: #38bdf8;
    cursor: pointer;
    box-shadow: 0 0 6px #38bdf8aa;
  }

  /* astro-island wrapper must not affect layout */
  astro-island {
    display: contents;
  }

  /* card background + border (can't be scoped in Svelte due to display:contents) */
  .info-card {
    background: #0d1220ee;
    backdrop-filter: blur(12px);
    border-left: 1px solid #1e2535;
  }
</style>
