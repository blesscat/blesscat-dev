---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import divesRaw from '../data/dives.json';
import skiRaw from '../data/ski.json';

const dives = divesRaw as any[];
const ski = skiRaw as any[];

const divesWithGPS = dives.filter(d => d.lat != null && d.lon != null);
const allYears = [
  ...dives.map(d => parseInt(d.date.slice(0, 4))),
  ...ski.map(d => parseInt(d.date.slice(0, 4))),
];
const yearMin = Math.min(...allYears);
const yearMax = Math.max(...allYears);
---

<Layout title="探索地圖" description="潛水潛點 × 滑雪雪場，橫跨多個國家的探索足跡" ogImage="/og/explore.png">
  <PageHeader title="🌏 探索地圖" subtitle="潛水潛點 × 滑雪雪場，點擊標記查看詳情" />

  <!-- 統計 mini bar -->
  <div id="explore-stats" class="flex items-center gap-3 bg-[#111827] border border-[#1e2535] rounded-[10px] px-[1.2rem] py-[0.6rem] mb-4 text-[0.82rem] flex-wrap anim-fade-up delay-2">
    <span class="stat-item">載入中⋯</span>
  </div>

  <!-- 控制列 -->
  <div class="flex items-center gap-4 mb-3 flex-wrap anim-fade-up delay-3 max-[480px]:gap-[0.6rem]">
    <div class="flex gap-2">
      <button id="toggle-dive" class="toggle-btn dive flex items-center gap-[0.4rem] py-[0.45rem] px-[0.9rem] rounded-full text-[0.8rem] font-semibold cursor-pointer border transition-all bg-[rgba(56,189,248,0.12)] border-[#38bdf8] text-[#38bdf8] max-[480px]:py-[0.4rem] max-[480px]:px-[0.7rem] max-[480px]:text-[0.75rem]">
        <span class="dot dive-dot w-2 h-2 rounded-full inline-block bg-[#38bdf8]"></span>🤿 潛水
      </button>
      <button id="toggle-ski" class="toggle-btn ski flex items-center gap-[0.4rem] py-[0.45rem] px-[0.9rem] rounded-full text-[0.8rem] font-semibold cursor-pointer border transition-all bg-[rgba(129,140,248,0.12)] border-[#818cf8] text-[#818cf8] max-[480px]:py-[0.4rem] max-[480px]:px-[0.7rem] max-[480px]:text-[0.75rem]">
        <span class="dot ski-dot w-2 h-2 rounded-full inline-block bg-[#818cf8]"></span>⛷️ 滑雪
      </button>
    </div>

    <div id="year-control" class="flex items-center gap-[0.6rem] ml-auto max-[768px]:ml-0">
      <span class="text-[0.75rem] text-[#475569] whitespace-nowrap">年份</span>
      <input id="year-slider" type="range"
        min={yearMin} max={yearMax} value={yearMax}
        class="year-slider appearance-none w-[140px] h-1 bg-[#1e2535] rounded-sm outline-none cursor-pointer max-[768px]:w-[100px]"
      />
      <span id="year-label" class="text-[0.75rem] text-[#38bdf8] bg-[rgba(56,189,248,0.1)] border border-[rgba(56,189,248,0.2)] rounded-[6px] px-2 py-[0.15rem] whitespace-nowrap">{yearMin} – {yearMax}</span>
    </div>
  </div>

  <!-- 地圖 + 側邊資訊卡 -->
  <div class="relative rounded-2xl overflow-hidden border border-[#1e2535] mb-8 anim-fade-up delay-4">
    <div id="explore-map" class="h-[580px] w-full bg-[#090d18] max-[768px]:h-[420px]"></div>
    <div id="info-card" class="info-card absolute top-0 right-[-360px] w-[340px] h-full bg-[#0d1220ee] backdrop-blur-[12px] border-l border-[#1e2535] overflow-y-auto transition-[right] duration-300 [transition-timing-function:cubic-bezier(0.22,1,0.36,1)] z-[1000] p-0 max-[768px]:top-auto max-[768px]:bottom-[-100%] max-[768px]:right-0 max-[768px]:w-full max-[768px]:h-[60%] max-[768px]:border-l-0 max-[768px]:border-t max-[768px]:border-t-[#1e2535] max-[768px]:rounded-t-2xl max-[768px]:[transition-property:bottom] max-[768px]:[transition-duration:300ms] max-[768px]:[transition-timing-function:cubic-bezier(0.22,1,0.36,1)]">
      <!-- 動態填入 -->
    </div>
  </div>
</Layout>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<!-- 傳資料給前端 -->
<script define:vars={{ dives, ski }} is:inline>
  window.__EXPLORE_DIVES__ = dives;
  window.__EXPLORE_SKI__ = ski;
</script>
<script>
  import '../scripts/explore-app.ts';
</script>

<style is:global>
  /* ── year slider thumb ── */
  .year-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 14px; height: 14px;
    border-radius: 50%;
    background: #38bdf8;
    cursor: pointer;
    box-shadow: 0 0 6px #38bdf8aa;
  }

  /* ── toggle off state (JS-toggled) ── */
  .toggle-btn.off {
    background: transparent !important;
    border-color: #1e2535 !important;
    color: #475569 !important;
  }
  .toggle-btn.off .dot {
    background: #475569 !important;
  }

  /* ── info card open state (JS-toggled) ── */
  .info-card.open {
    right: 0;
  }
  @media (max-width: 768px) {
    .info-card.open {
      bottom: 0;
      right: 0;
    }
  }

  /* ── stats bar items (JS-injected via updateStats) ── */
  .stat-item { color: #94a3b8; }
  .stat-item strong { color: #e2e8f0; }
  .dive-stat strong { color: #38bdf8; }
  .ski-stat strong { color: #818cf8; }
  .stat-sep { color: #1e2535; }

  /* ── card content (JS-injected via openDiveCard / openSkiCard) ── */
  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.2rem 0.75rem;
    border-bottom: 1px solid #1e2535;
    position: sticky;
    top: 0;
    background: #0d1220ee;
    backdrop-filter: blur(8px);
    z-index: 10;
  }
  .card-type {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 0.2rem 0.6rem;
    border-radius: 99px;
  }
  .card-type.dive { background: rgba(56,189,248,0.15); color: #38bdf8; }
  .card-type.ski  { background: rgba(129,140,248,0.15); color: #818cf8; }
  .card-close {
    background: transparent;
    border: none;
    color: #475569;
    font-size: 0.9rem;
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    transition: color 0.2s;
  }
  .card-close:hover { color: #e2e8f0; }
  .card-title {
    font-size: 1.1rem;
    font-weight: 800;
    color: #e2e8f0;
    padding: 0.9rem 1.2rem 0.2rem;
    line-height: 1.3;
  }
  .card-count {
    font-size: 0.72rem;
    color: #475569;
    padding: 0 1.2rem 0.75rem;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  /* ski summary */
  .card-summary {
    display: flex;
    gap: 0;
    border-top: 1px solid #1e2535;
    border-bottom: 1px solid #1e2535;
    margin-bottom: 0.5rem;
  }
  .summary-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0.75rem 0.5rem;
    border-right: 1px solid #1e2535;
  }
  .summary-item:last-child { border-right: none; }
  .s-num { font-size: 1.1rem; font-weight: 800; color: #818cf8; }
  .s-lbl { font-size: 0.6rem; color: #475569; text-transform: uppercase; letter-spacing: 1px; margin-top: 2px; }

  /* entries */
  .card-entries { padding: 0 1.2rem 1.5rem; }
  .entry { padding: 0.75rem 0; }
  .entry-border { border-top: 1px solid #1e2535; }
  .entry-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.4rem;
  }
  .entry-num { font-size: 0.72rem; color: #475569; font-weight: 700; }
  .entry-date { font-size: 0.78rem; color: #64748b; }
  .entry-country { font-size: 0.72rem; color: #475569; margin-left: auto; }

  /* pills */
  .entry-pills { display: flex; gap: 0.3rem; flex-wrap: wrap; }
  .pill { padding: 0.18rem 0.5rem; border-radius: 99px; font-size: 0.7rem; font-weight: 600; }
  .pill.depth { background: #0c2d48; color: #38bdf8; }
  .pill.time  { background: #1a1a2e; color: #818cf8; }
  .pill.temp  { background: #1a2e1a; color: #4ade80; }
  .pill.gas   { background: #2e1a1a; color: #f87171; }
  .pill.hr    { background: #2e1a1a; color: #fb7185; }
  .pill.runs  { background: #1e1a2e; color: #818cf8; }
  .pill.speed { background: #2e1a1a; color: #f87171; }
  .pill.vert  { background: #0c2d48; color: #38bdf8; }
  .pill.alt   { background: #1e1a10; color: #fbbf24; }
  .pill.dur   { background: #1a2520; color: #34d399; }

  /* depth chart */
  .chart-btn {
    margin-top: 0.5rem;
    padding: 0.3rem 0.75rem;
    background: transparent;
    border: 1px solid #1e2535;
    border-radius: 6px;
    color: #38bdf8;
    font-size: 0.72rem;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .chart-btn:hover { border-color: #38bdf8; }
  .chart-wrap { margin-top: 0.6rem; height: 140px; position: relative; }
</style>
