---
import Layout from '../layouts/Layout.astro';
import type { Dive } from '../types/dive';
import divesRaw from '../data/dives.json';
import skiRaw from '../data/ski.json';

const dives = divesRaw as Dive[];
const ski = skiRaw as any[];

const totalDives = dives.length;
const maxDepth = Math.max(...dives.map(d => d.max_depth || 0));
const totalDiveMinutes = dives.reduce((s, d) => s + (d.bottom_time || 0), 0);
const totalDiveHours = Math.floor(totalDiveMinutes / 60);

const totalSkiDays = ski.length;
const maxSpeed = Math.max(...ski.map(d => d.top_speed_kmh || 0));
const totalVertical = ski.reduce((s, d) => s + (d.vertical_m || 0), 0);
---
<Layout title="Home">
  <div class="hero">

    <!-- 左：簡介 -->
    <div class="left anim-fade-up delay-1">
      <p class="kicker">Explorer · Since 2024</p>
      <h1>blesscat<span>.dev</span></h1>
      <p class="desc">
        潛過太平洋的珊瑚礁，滑過日本的粉雪斜坡，
        順便把 AI agent 搞爆幾次。
        這裡是我的探索紀錄。
      </p>
      <div class="cta-row">
        <a href="/dives" class="btn-primary">🤿 潛水紀錄</a>
        <a href="/ski" class="btn-ski">⛷️ 滑雪紀錄</a>
        <a href="/blog" class="btn-secondary">📝 日記</a>
      </div>
    </div>

    <!-- 右：2×2 數字卡 -->
    <div class="right">
      <div class="stat-card dive anim-fade-up delay-2">
        <div class="card-icon">🤿</div>
        <div class="card-num count-up" data-target={totalDives} data-decimals="0">{totalDives}</div>
        <div class="card-label">次潛水</div>
      </div>
      <div class="stat-card dive anim-fade-up delay-3">
        <div class="card-icon">▼</div>
        <div class="card-num count-up" data-target={maxDepth} data-decimals="1" data-suffix="m">{maxDepth.toFixed(1)}m</div>
        <div class="card-label">最大深度</div>
      </div>
      <div class="stat-card ski anim-fade-up delay-4">
        <div class="card-icon">⛷️</div>
        <div class="card-num count-up" data-target={totalSkiDays} data-decimals="0">{totalSkiDays}</div>
        <div class="card-label">滑雪天數</div>
      </div>
      <div class="stat-card ski anim-fade-up delay-5">
        <div class="card-icon">⚡</div>
        <div class="card-num count-up" data-target={maxSpeed} data-decimals="1" data-suffix="km/h">{maxSpeed.toFixed(1)}km/h</div>
        <div class="card-label">最高速度</div>
      </div>
    </div>

  </div>
</Layout>

<script>
  function animateCountUp(el: HTMLElement) {
    const target = parseFloat(el.dataset.target || '0');
    const decimals = parseInt(el.dataset.decimals || '0');
    const suffix = el.dataset.suffix || '';
    const duration = 1200;
    const start = performance.now();
    function tick(now: number) {
      const progress = Math.min((now - start) / duration, 1);
      const ease = 1 - Math.pow(1 - progress, 3);
      el.textContent = (target * ease).toFixed(decimals) + suffix;
      if (progress < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }
  const counters = document.querySelectorAll<HTMLElement>('.count-up');
  const io = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        animateCountUp(entry.target as HTMLElement);
        io.unobserve(entry.target);
      }
    });
  }, { threshold: 0.3 });
  counters.forEach(el => io.observe(el));
</script>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 4rem;
    align-items: center;
    min-height: 80vh;
  }

  /* ── 左欄 ── */
  .left { display: flex; flex-direction: column; }

  .kicker {
    font-size: 0.72rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #38bdf8;
    border-left: 2px solid #38bdf8;
    padding-left: 10px;
    margin-bottom: 1rem;
  }

  h1 {
    font-size: 3.8rem;
    font-weight: 900;
    color: #e2e8f0;
    letter-spacing: -2px;
    line-height: 1;
    margin-bottom: 1.2rem;
    animation: pulse-glow 4s ease-in-out infinite;
  }
  h1 span { color: #38bdf8; }

  .desc {
    color: #64748b;
    font-size: 1rem;
    line-height: 1.75;
    margin-bottom: 2rem;
  }

  .cta-row { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  .btn-primary {
    padding: 0.75rem 1.6rem;
    background: #38bdf8;
    color: #0a0e1a;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(56,189,248,0.35);
  }

  .btn-ski {
    padding: 0.75rem 1.6rem;
    background: #818cf8;
    color: #0a0e1a;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .btn-ski:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(129,140,248,0.35);
  }

  .btn-secondary {
    padding: 0.75rem 1.6rem;
    border: 1px solid #1e2535;
    color: #64748b;
    border-radius: 8px;
    text-decoration: none;
    font-size: 0.9rem;
    transition: border-color 0.2s, color 0.2s, transform 0.2s;
  }
  .btn-secondary:hover {
    border-color: #38bdf8;
    color: #e2e8f0;
    transform: translateY(-2px);
  }

  /* ── 右欄 2×2 卡片 ── */
  .right {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .stat-card {
    background: #111827;
    border: 1px solid #1e2535;
    border-radius: 16px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
  }
  .stat-card:hover {
    transform: translateY(-4px);
  }
  .stat-card.dive:hover {
    border-color: #38bdf8;
    box-shadow: 0 8px 28px rgba(56,189,248,0.12);
  }
  .stat-card.ski:hover {
    border-color: #818cf8;
    box-shadow: 0 8px 28px rgba(129,140,248,0.12);
  }

  .card-icon { font-size: 1.2rem; margin-bottom: 0.4rem; }

  .card-num {
    font-size: 2rem;
    font-weight: 900;
    letter-spacing: -0.5px;
    line-height: 1;
  }
  .stat-card.dive .card-num { color: #38bdf8; }
  .stat-card.ski  .card-num { color: #818cf8; }

  .card-label {
    font-size: 0.72rem;
    color: #475569;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-top: 0.2rem;
  }

  /* ── RWD ── */
  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      min-height: unset;
      padding: 2rem 0;
    }
    h1 { font-size: 2.8rem; }
    .right { grid-template-columns: 1fr 1fr; }
    .card-num { font-size: 1.6rem; }
  }

  @media (max-width: 480px) {
    h1 { font-size: 2.2rem; }
    .cta-row { gap: 0.5rem; }
    .btn-primary, .btn-ski, .btn-secondary { padding: 0.65rem 1.2rem; font-size: 0.85rem; }
  }
</style>
