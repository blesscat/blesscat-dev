---
import Layout from '../layouts/Layout.astro'
import type { Dive } from '../types/dive'
import type { Ski } from '../types/ski'
import divesRaw from '../data/dives.json'
import skiRaw from '../data/ski.json'

const dives = divesRaw as Dive[]
const ski = skiRaw as Ski[]

const totalDives = dives.length
const maxDepth = Math.max(...dives.map(d => d.max_depth || 0))
const totalSkiDays = ski.length
const maxSpeed = Math.max(...ski.map(d => d.top_speed_kmh || 0))
---
<Layout title="Home" description="潛水、滑雪、探索、搗鼓 AI — Blesscat 的個人紀錄網站" ogImage="/og/index.png">
  <div class="grid grid-cols-[1.1fr_1fr] gap-16 items-center min-h-[80vh] relative max-md:grid-cols-1 max-md:gap-10 max-md:min-h-0 max-md:py-8">

    <!-- 左：簡介 -->
    <div class="flex flex-col anim-fade-up delay-1">
      <p class="text-[0.72rem] tracking-[3px] uppercase text-muted border-l-2 border-[#dad4c8] pl-[10px] mb-4 font-medium">
        Explorer · Since 2024
      </p>
      <h1 class="text-[3.8rem] font-black text-text tracking-[-2px] leading-none mb-5 max-md:text-[2.8rem] max-[480px]:text-[2.2rem]">
        blesscat<span class="text-[#3bd3fd]">.dev</span>
      </h1>
      <p class="text-muted text-base leading-[1.75] mb-8">
        潛過太平洋的珊瑚礁，滑過日本的粉雪斜坡，<br/>
        順便把 AI agent 搞爆幾次。<br/>
        這裡是我的探索紀錄。
      </p>
      <div class="flex gap-3 flex-wrap max-[480px]:gap-2">
        <a href="/dives"
           class="px-6 py-3 bg-[#3bd3fd] text-black rounded-2xl no-underline font-bold text-[0.9rem] transition-all btn-clay max-[480px]:px-5 max-[480px]:py-[0.65rem] max-[480px]:text-[0.85rem]">
          🤿 潛水紀錄
        </a>
        <a href="/ski"
           class="px-6 py-3 bg-[#84e7a5] text-black rounded-2xl no-underline font-bold text-[0.9rem] transition-all btn-clay max-[480px]:px-5 max-[480px]:py-[0.65rem] max-[480px]:text-[0.85rem]">
          ⛷️ 滑雪紀錄
        </a>
        <a href="/explore"
           class="px-6 py-3 bg-[#f8cc65] text-black rounded-2xl no-underline font-bold text-[0.9rem] transition-all btn-clay max-[480px]:px-5 max-[480px]:py-[0.65rem] max-[480px]:text-[0.85rem]">
          🌏 探索地圖
        </a>
        <a href="/blog"
           class="px-6 py-3 bg-surface border-2 border-[#dad4c8] text-[#55534e] dark:text-[#a89e94] rounded-2xl no-underline font-bold text-[0.9rem] transition-all hover:border-[#000] hover:text-black dark:hover:border-[#84e7a5] btn-clay">
          📝 日記
        </a>
      </div>
    </div>

    <!-- 右：2×2 數字卡 (Clay Bento Grid) -->
    <div class="grid grid-cols-2 gap-4">
      <div class="bento-clay p-6 flex flex-col gap-1 transition-all duration-250 hover:-translate-y-2 hover:shadow-[-4px_8px_0px_#dad4c8] anim-fade-up delay-2 cursor-default">
        <div class="text-xl mb-2">🤿</div>
        <div class="text-[2rem] font-black tracking-[-0.5px] leading-none text-[#3bd3fd] count-up max-md:text-[1.6rem]"
             data-target={totalDives} data-decimals="0">{totalDives}</div>
        <div class="text-[0.72rem] text-subtle uppercase tracking-[1.5px] mt-1">次潛水</div>
      </div>
      <div class="bento-clay p-6 flex flex-col gap-1 transition-all duration-250 hover:-translate-y-2 hover:shadow-[-4px_8px_0px_#dad4c8] anim-fade-up delay-3 cursor-default">
        <div class="text-xl mb-2">▼</div>
        <div class="text-[2rem] font-black tracking-[-0.5px] leading-none text-[#3bd3fd] count-up max-md:text-[1.6rem]"
             data-target={maxDepth} data-decimals="1" data-suffix="m">{maxDepth.toFixed(1)}m</div>
        <div class="text-[0.72rem] text-subtle uppercase tracking-[1.5px] mt-1">最大深度</div>
      </div>
      <div class="bento-clay p-6 flex flex-col gap-1 transition-all duration-250 hover:-translate-y-2 hover:shadow-[-4px_8px_0px_#dad4c8] anim-fade-up delay-4 cursor-default">
        <div class="text-xl mb-2">⛷️</div>
        <div class="text-[2rem] font-black tracking-[-0.5px] leading-none text-[#84e7a5] count-up max-md:text-[1.6rem]"
             data-target={totalSkiDays} data-decimals="0">{totalSkiDays}</div>
        <div class="text-[0.72rem] text-subtle uppercase tracking-[1.5px] mt-1">滑雪天數</div>
      </div>
      <div class="bento-clay p-6 flex flex-col gap-1 transition-all duration-250 hover:-translate-y-2 hover:shadow-[-4px_8px_0px_#dad4c8] anim-fade-up delay-5 cursor-default">
        <div class="text-xl mb-2">⚡</div>
        <div class="text-[2rem] font-black tracking-[-0.5px] leading-none text-[#84e7a5] count-up max-md:text-[1.6rem]"
             data-target={maxSpeed} data-decimals="1" data-suffix="km/h">{maxSpeed.toFixed(1)}km/h</div>
        <div class="text-[0.72rem] text-subtle uppercase tracking-[1.5px] mt-1">最高速度</div>
      </div>
    </div>

  </div>
</Layout>

<script>
  import '../scripts/count-up.ts'
</script>
