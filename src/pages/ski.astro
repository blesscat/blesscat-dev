---
import Layout from '../layouts/Layout.astro';
import skiRaw from '../data/ski.json';

const ski = skiRaw as any[];

const totalDays = ski.length;
const totalRuns = ski.reduce((s, d) => s + (d.runs || 0), 0);
const totalVertical = ski.reduce((s, d) => s + (d.vertical_m || 0), 0);
const totalDistance = ski.reduce((s, d) => s + (d.distance_m || 0), 0);
const totalDuration = ski.reduce((s, d) => s + (d.duration_s || 0), 0);
const totalHours = Math.floor(totalDuration / 3600);
const totalMins = Math.floor((totalDuration % 3600) / 60);
const maxSpeed = Math.max(...ski.map(d => d.top_speed_kmh || 0));
const maxSpeedDay = ski.find(d => d.top_speed_kmh === maxSpeed);
const maxAlt = Math.max(...ski.map(d => d.peak_altitude_m || 0));
const maxAltDay = ski.find(d => d.peak_altitude_m === maxAlt);
const totalLifts = ski.reduce((s, d) => s + (d.lifts || 0), 0);
const resorts = [...new Set(ski.map(d => d.resort.split('/')[0].trim()))].length;

// 月份分布
const monthCount: Record<string, number> = {};
ski.forEach(d => {
  const m = d.date.slice(0, 7);
  monthCount[m] = (monthCount[m] || 0) + 1;
});
const months = Object.keys(monthCount).sort();
---

<Layout title="滑雪紀錄" description={`${totalDays} 天滑雪 · 最高速 ${maxSpeed.toFixed(1)}km/h · 累計落差 ${(totalVertical/1000).toFixed(1)}km`} ogImage="/og/ski.png">
  <div class="page-header">
    <h1>⛷️ 滑雪紀錄</h1>
    <p class="subtitle">日本雪場巡禮</p>
  </div>

  <!-- 統計卡片 -->
  <div class="stats-grid">
    <div class="card stat-card anim-fade-up delay-1">
      <div class="stat-num count-up" data-target={totalDays} data-decimals="0">{totalDays}</div>
      <div class="stat-label">滑雪天數</div>
    </div>
    <div class="card stat-card anim-fade-up delay-2">
      <div class="stat-num count-up" data-target={totalRuns} data-decimals="0">{totalRuns}</div>
      <div class="stat-label">總滑行次數</div>
    </div>
    <div class="card stat-card anim-fade-up delay-3">
      <div class="stat-num count-up" data-target={totalVertical / 1000} data-decimals="1" data-suffix="km">{(totalVertical / 1000).toFixed(1)}km</div>
      <div class="stat-label">累計垂直落差</div>
    </div>
    <div class="card stat-card anim-fade-up delay-4">
      <div class="stat-num count-up" data-target={maxSpeed} data-decimals="1" data-suffix="km/h">{maxSpeed.toFixed(1)}<span class="stat-unit">km/h</span></div>
      <div class="stat-label">最高速度</div>
      <div class="stat-sub">{maxSpeedDay?.resort}</div>
    </div>
    <div class="card stat-card anim-fade-up delay-5">
      <div class="stat-num count-up" data-target={totalHours} data-decimals="0" data-suffix={`h ${totalMins}m`}>{totalHours}h {totalMins}m</div>
      <div class="stat-label">總滑行時間</div>
    </div>
    <div class="card stat-card anim-fade-up delay-6">
      <div class="stat-num count-up" data-target={maxAlt} data-decimals="0" data-suffix="m">{maxAlt.toFixed(0)}<span class="stat-unit">m</span></div>
      <div class="stat-label">最高海拔</div>
      <div class="stat-sub">{maxAltDay?.resort}</div>
    </div>
    <div class="card stat-card anim-fade-up delay-7">
      <div class="stat-num count-up" data-target={totalDistance / 1000} data-decimals="1" data-suffix="km">{(totalDistance / 1000).toFixed(1)}km</div>
      <div class="stat-label">總滑行距離</div>
    </div>
    <div class="card stat-card anim-fade-up delay-8">
      <div class="stat-num count-up" data-target={totalLifts} data-decimals="0">{totalLifts}</div>
      <div class="stat-label">總搭纜車次數</div>
    </div>
    <div class="card stat-card anim-fade-up delay-8">
      <div class="stat-num count-up" data-target={resorts} data-decimals="0">{resorts}</div>
      <div class="stat-label">造訪雪場</div>
    </div>
  </div>

  <!-- 地圖 -->
  <div class="section">
    <h2>雪場地圖</h2>
    <div id="ski-map" class="map-container"></div>
  </div>

  <!-- 圖表區 -->
  <div class="charts-grid section">
    <!-- 速度分布 -->
    <div class="card chart-card">
      <h3>各天最高速度 <span class="badge">km/h</span></h3>
      <div class="chart-wrapper">
        <canvas id="speed-chart"></canvas>
      </div>
    </div>
    <!-- 月份分布 -->
    <div class="card chart-card">
      <h3>月份滑雪天數</h3>
      <div class="chart-wrapper">
        <canvas id="month-chart"></canvas>
      </div>
    </div>
    <!-- 速度 vs 垂直落差 散點圖 -->
    <div class="card chart-card">
      <h3>速度 vs 垂直落差 <span class="badge">scatter</span></h3>
      <div class="chart-wrapper">
        <canvas id="scatter-chart"></canvas>
      </div>
    </div>
    <!-- 雪場比較橫條圖 -->
    <div class="card chart-card">
      <h3>雪場總滑行次數 <span class="badge">runs</span></h3>
      <div class="chart-wrapper">
        <canvas id="resort-chart"></canvas>
      </div>
    </div>
    <!-- 年度比較 grouped bar chart -->
    <div class="card chart-card chart-card--full">
      <h3>年度比較 <span class="badge">滑雪天數 vs 總 runs</span></h3>
      <div class="chart-wrapper" style="height:200px;">
        <canvas id="year-compare-chart"></canvas>
      </div>
    </div>
  </div>

  <!-- 滑雪列表 -->
  <div class="section">
    <h2>所有紀錄</h2>

    <!-- 篩選列 -->
    <div class="filter-bar">
      <input
        id="ski-search"
        type="search"
        placeholder="搜尋雪場名稱…"
        class="filter-input"
        autocomplete="off"
      />
      <select id="ski-year" class="filter-select">
        <option value="">全部年份</option>
        <option value="2024">2024</option>
        <option value="2025">2025</option>
        <option value="2026">2026</option>
      </select>
      <span id="ski-count" class="filter-count">顯示 {ski.length} / {ski.length} 筆</span>
    </div>

    <div class="ski-list">
      {ski.map(d => (
        <div class="ski-row card reveal">
          <div class="ski-date">{d.date}</div>
          <div class="ski-info">
            <div class="ski-resort">{d.resort}</div>
            <div class="ski-country">{d.country}</div>
          </div>
          <div class="ski-stats">
            <span class="pill runs">🎿 {d.runs} runs</span>
            <span class="pill lifts">🚡 {d.lifts} lifts</span>
            <span class="pill vert">↕ {(d.vertical_m / 1000).toFixed(2)}km</span>
            <span class="pill dist">📏 {(d.distance_m / 1000).toFixed(1)}km</span>
            <span class="pill speed">💨 {d.top_speed_kmh.toFixed(1)}km/h</span>
            <span class="pill time">⏱ {Math.floor(d.duration_s/3600)}h{Math.floor((d.duration_s%3600)/60)}m</span>
            <span class="pill alt">🏔 {d.peak_altitude_m.toFixed(0)}m</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>

<script define:vars={{ ski, months, monthCount, totalCount: ski.length }}>
  window.__SKI_DATA__ = ski;
  window.__SKI_MONTHS__ = months;
  window.__SKI_MONTH_COUNT__ = monthCount;
  window.__SKI_TOTAL__ = totalCount;
</script>

<script>
  // 搜尋篩選
  (function () {
    const searchEl = document.getElementById('ski-search') as HTMLInputElement | null;
    const yearEl = document.getElementById('ski-year') as HTMLSelectElement | null;
    const countEl = document.getElementById('ski-count');
    const rows = document.querySelectorAll<HTMLElement>('.ski-row');
    const total = (window as any).__SKI_TOTAL__ || rows.length;

    function applyFilter() {
      const keyword = searchEl ? searchEl.value.trim().toLowerCase() : '';
      const year = yearEl ? yearEl.value : '';
      let visible = 0;
      rows.forEach(row => {
        const resort = (row.querySelector('.ski-resort')?.textContent || '').toLowerCase();
        const date = (row.querySelector('.ski-date')?.textContent || '');
        const matchKeyword = !keyword || resort.includes(keyword);
        const matchYear = !year || date.startsWith(year);
        if (matchKeyword && matchYear) {
          row.style.display = '';
          visible++;
        } else {
          row.style.display = 'none';
        }
      });
      if (countEl) countEl.textContent = `顯示 ${visible} / ${total} 筆`;
    }

    if (searchEl) searchEl.addEventListener('input', applyFilter);
    if (yearEl) yearEl.addEventListener('change', applyFilter);
    applyFilter();
  })();
</script>

<script>
  // 地圖
  (function () {
    const script = document.createElement('script');
    script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
    script.onload = function () {
      const ghCss = document.createElement('link');
      ghCss.rel = 'stylesheet';
      ghCss.href = 'https://unpkg.com/leaflet-gesture-handling@1.4.0/dist/leaflet-gesture-handling.min.css';
      document.head.appendChild(ghCss);
      const gh = document.createElement('script');
      gh.src = 'https://unpkg.com/leaflet-gesture-handling@1.4.0/dist/leaflet-gesture-handling.min.js';
      gh.onload = function () {
        const L = window.L;
        const data = window.__SKI_DATA__ || [];
        const map = L.map('ski-map', { zoomControl: true, gestureHandling: true });
      L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; OpenStreetMap &copy; CARTO', maxZoom: 18,
      }).addTo(map);
      const icon = L.divIcon({
        html: `<div style="width:12px;height:12px;border-radius:50%;background:#818cf8;border:2px solid #fff;box-shadow:0 0 8px #818cf8;"></div>`,
        className: '', iconSize: [12, 12], iconAnchor: [6, 6],
      });
      const markers = [];
      data.forEach(d => {
        if (d.lat == null || d.lon == null) return;
        const marker = L.marker([d.lat, d.lon], { icon }).addTo(map).bindTooltip(
          `<div style="font-family:sans-serif;color:#0f172a;min-width:140px;max-width:200px;word-break:break-word;white-space:normal;">
            <div style="font-weight:700;font-size:1rem;margin-bottom:4px;line-height:1.3;">${d.resort}</div>
            <div style="color:#64748b;font-size:0.82rem;">${d.date}</div>
            <div style="margin-top:8px;display:flex;gap:6px;flex-wrap:wrap;">
              <span style="background:#ede9fe;color:#7c3aed;padding:2px 8px;border-radius:99px;font-size:0.78rem;">🎿 ${d.runs} runs</span>
              <span style="background:#fef3c7;color:#d97706;padding:2px 8px;border-radius:99px;font-size:0.78rem;">💨 ${d.top_speed_kmh.toFixed(1)}km/h</span>
              <span style="background:#f0fdf4;color:#16a34a;padding:2px 8px;border-radius:99px;font-size:0.78rem;">🏔 ${d.peak_altitude_m.toFixed(0)}m</span>
            </div>
          </div>`,
          { sticky: true }
        );
        markers.push(marker);
      });
      if (markers.length) {
        const group = L.featureGroup(markers);
        map.fitBounds(group.getBounds().pad(0.3));
      }
      };
      document.head.appendChild(gh);
    };
    document.head.appendChild(script);
  })();

  // Chart.js
  (function () {
    const script = document.createElement('script');
    script.src = 'https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js';
    script.onload = function () {
      const data = window.__SKI_DATA__ || [];
      const months = window.__SKI_MONTHS__ || [];
      const monthCount = window.__SKI_MONTH_COUNT__ || {};
      const isMobile = window.innerWidth < 640;

      // 速度分布 bar chart（由高到低排序）
      const sorted = [...data].sort((a, b) => b.top_speed_kmh - a.top_speed_kmh);
      const speedCtx = document.getElementById('speed-chart').getContext('2d');
      new window.Chart(speedCtx, {
        type: 'bar',
        data: {
          labels: sorted.map(d => isMobile ? d.date.slice(5) : d.date),
          datasets: [{
            label: '最高速度 (km/h)',
            data: sorted.map(d => d.top_speed_kmh.toFixed(1)),
            backgroundColor: sorted.map(d =>
              d.top_speed_kmh === Math.max(...data.map(x => x.top_speed_kmh))
                ? '#f87171' : '#818cf8'
            ),
            borderRadius: 4,
          }],
        },
        options: {
          responsive: true, maintainAspectRatio: false, animation: false,
          plugins: {
            legend: { display: false },
            tooltip: { callbacks: { label: c => `${c.raw} km/h` } },
          },
          scales: {
            x: {
              ticks: { color: '#475569', font: { size: isMobile ? 9 : 11 }, maxRotation: 45 },
              grid: { color: '#1e2535' },
            },
            y: {
              ticks: { color: '#818cf8', font: { size: isMobile ? 10 : 12 }, callback: v => v + ' km/h' },
              grid: { color: '#1e2535' },
            },
          },
        },
      });

      // 月份分布
      const monthCtx = document.getElementById('month-chart').getContext('2d');
      new window.Chart(monthCtx, {
        type: 'bar',
        data: {
          labels: months,
          datasets: [{
            label: '滑雪天數',
            data: months.map(m => monthCount[m]),
            backgroundColor: '#38bdf8',
            borderRadius: 4,
          }],
        },
        options: {
          responsive: true, maintainAspectRatio: false, animation: false,
          plugins: {
            legend: { display: false },
            tooltip: { callbacks: { label: c => `${c.raw} 天` } },
          },
          scales: {
            x: {
              ticks: { color: '#475569', font: { size: isMobile ? 10 : 12 } },
              grid: { color: '#1e2535' },
            },
            y: {
              ticks: { color: '#38bdf8', font: { size: isMobile ? 10 : 12 }, stepSize: 1 },
              grid: { color: '#1e2535' },
            },
          },
        },
      });

      // 速度 vs 垂直落差 散點圖
      const scatterCtx = document.getElementById('scatter-chart').getContext('2d');
      const scatterData = data
        .filter(d => d.vertical_m != null && d.top_speed_kmh != null)
        .map(d => ({
          x: parseFloat((d.vertical_m / 1000).toFixed(2)),
          y: parseFloat(d.top_speed_kmh.toFixed(1)),
          resort: d.resort,
          date: d.date,
        }));
      new window.Chart(scatterCtx, {
        type: 'scatter',
        data: {
          datasets: [{
            label: '速度 vs 垂直落差',
            data: scatterData,
            backgroundColor: '#f87171',
            pointRadius: 8,
            pointHoverRadius: 10,
          }],
        },
        options: {
          responsive: true, maintainAspectRatio: false, animation: false,
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: c => {
                  const d = scatterData[c.dataIndex];
                  return [`${d.resort}`, `${d.date}`, `垂直: ${c.parsed.x}km  速度: ${c.parsed.y}km/h`];
                },
              },
            },
          },
          scales: {
            x: {
              title: { display: true, text: '垂直落差 (km)', color: '#475569', font: { size: 11 } },
              ticks: { color: '#475569', font: { size: isMobile ? 9 : 11 } },
              grid: { color: '#1e2535' },
            },
            y: {
              title: { display: true, text: '最高速 (km/h)', color: '#475569', font: { size: 11 } },
              ticks: { color: '#f87171', font: { size: isMobile ? 10 : 12 }, callback: v => v + ' km/h' },
              grid: { color: '#1e2535' },
            },
          },
        },
      });

      // 雪場比較橫條圖
      const resortRuns = {};
      data.forEach(d => {
        const name = d.resort.split('/')[0].trim();
        resortRuns[name] = (resortRuns[name] || 0) + (d.runs || 0);
      });
      const resortsSorted = Object.entries(resortRuns).sort((a, b) => b[1] - a[1]);
      const resortCtx = document.getElementById('resort-chart').getContext('2d');
      new window.Chart(resortCtx, {
        type: 'bar',
        data: {
          labels: resortsSorted.map(r => r[0]),
          datasets: [{
            label: '總 runs',
            data: resortsSorted.map(r => r[1]),
            backgroundColor: '#818cf8',
            borderRadius: 4,
          }],
        },
        options: {
          indexAxis: 'y',
          responsive: true, maintainAspectRatio: false, animation: false,
          plugins: {
            legend: { display: false },
            tooltip: { callbacks: { label: c => `${c.raw} runs` } },
          },
          scales: {
            x: {
              ticks: { color: '#818cf8', font: { size: isMobile ? 9 : 11 }, callback: v => v + ' runs' },
              grid: { color: '#1e2535' },
            },
            y: {
              ticks: { color: '#94a3b8', font: { size: isMobile ? 9 : 11 } },
              grid: { color: '#1e2535' },
            },
          },
        },
      });

      // 年度比較 grouped bar chart
      const yearData = window.__SKI_YEAR_DATA__;
      const yearCtx = document.getElementById('year-compare-chart').getContext('2d');
      if (yearData && yearCtx) {
        new window.Chart(yearCtx, {
          type: 'bar',
          data: {
            labels: yearData.labels,
            datasets: [
              {
                label: '滑雪天數',
                data: yearData.days,
                backgroundColor: ['#38bdf8', '#818cf8', '#4ade80'],
                borderRadius: 6,
                borderSkipped: false,
              },
              {
                label: '總 runs',
                data: yearData.runs,
                backgroundColor: ['rgba(56,189,248,0.4)', 'rgba(129,140,248,0.4)', 'rgba(74,222,128,0.4)'],
                borderRadius: 6,
                borderSkipped: false,
              }
            ]
          },
          options: {
            responsive: true, maintainAspectRatio: false, animation: false,
            plugins: {
              legend: { display: true, labels: { color: '#94a3b8', font: { size: 12 } } },
              tooltip: {
                callbacks: {
                  label: c => c.datasetIndex === 0 ? ` ${c.raw} 天` : ` ${c.raw} runs`
                }
              }
            },
            scales: {
              x: { grid: { color: '#1e2535' }, ticks: { color: '#94a3b8', font: { size: 13 } } },
              y: { grid: { color: '#1e2535' }, ticks: { color: '#94a3b8' }, beginAtZero: true }
            }
          }
        });
      }
    };
    document.head.appendChild(script);
  })();
</script>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<script>
  function animateCountUp(el: HTMLElement) {
    const target = parseFloat(el.dataset.target || '0');
    const decimals = parseInt(el.dataset.decimals || '0');
    const suffix = el.dataset.suffix || '';
    const duration = 1100;
    const start = performance.now();
    function tick(now: number) {
      const progress = Math.min((now - start) / duration, 1);
      const ease = 1 - Math.pow(1 - progress, 3);
      el.textContent = (target * ease).toFixed(decimals) + suffix;
      if (progress < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }
  const counters = document.querySelectorAll<HTMLElement>('.count-up');
  const io = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        animateCountUp(entry.target as HTMLElement);
        io.unobserve(entry.target);
      }
    });
  }, { threshold: 0.4 });
  counters.forEach(el => io.observe(el));
</script>

<style>
  .page-header { margin-bottom: 2rem; }
  .subtitle { color: #64748b; margin-top: 0.3rem; }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .card {
    background: #111827;
    border: 1px solid #1e2535;
    border-radius: 12px;
    padding: 1.5rem;
  }
  .stat-card { text-align: center; }
  .stat-num { font-size: 1.8rem; font-weight: 800; color: #818cf8; }
  .stat-unit { font-size: 0.9rem; font-weight: 600; }
  .stat-label { font-size: 0.75rem; color: #64748b; text-transform: uppercase; letter-spacing: 1px; margin-top: 0.25rem; }
  .stat-sub { font-size: 0.72rem; color: #475569; margin-top: 0.2rem; }
  .section { margin-bottom: 3rem; }
  .map-container { height: 450px; border-radius: 12px; overflow: hidden; border: 1px solid #1e2535; }

  /* 圖表區 */
  .charts-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .chart-card h3 { font-size: 0.9rem; color: #94a3b8; margin: 0 0 1rem; font-weight: 600; }
  .chart-card--full { grid-column: 1 / -1; }
  .badge {
    font-size: 0.68rem; background: #1e1a2e; color: #818cf8;
    padding: 0.15rem 0.4rem; border-radius: 4px; vertical-align: middle;
  }
  .chart-wrapper { position: relative; height: 220px; }

  /* 篩選列 */
  .filter-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .filter-input {
    flex: 1;
    min-width: 180px;
    background: #111827;
    border: 1px solid #1e2535;
    border-radius: 8px;
    color: #94a3b8;
    padding: 0.5rem 0.85rem;
    font-size: 0.88rem;
    outline: none;
    transition: border-color 0.2s;
  }
  .filter-input::placeholder { color: #475569; }
  .filter-input:focus { border-color: #818cf8; }
  .filter-select {
    background: #111827;
    border: 1px solid #1e2535;
    border-radius: 8px;
    color: #94a3b8;
    padding: 0.5rem 0.75rem;
    font-size: 0.88rem;
    outline: none;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .filter-select:focus { border-color: #818cf8; }
  .filter-count {
    font-size: 0.78rem;
    color: #475569;
    white-space: nowrap;
    margin-left: auto;
  }

  /* 列表 */
  .ski-list { display: flex; flex-direction: column; gap: 0.6rem; }
  .ski-row {
