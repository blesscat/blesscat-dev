---
import Layout from '../layouts/Layout.astro'
import PageHeader from '../components/PageHeader.astro'
import StatCard from '../components/StatCard.astro'
import MapSection from '../components/MapSection.astro'
import skiRaw from '../data/ski.json'

const ski = skiRaw as any[]

const totalDays = ski.length
const totalRuns = ski.reduce((s, d) => s + (d.runs || 0), 0)
const totalVertical = ski.reduce((s, d) => s + (d.vertical_m || 0), 0)
const totalDistance = ski.reduce((s, d) => s + (d.distance_m || 0), 0)
const totalDuration = ski.reduce((s, d) => s + (d.duration_s || 0), 0)
const totalHours = Math.floor(totalDuration / 3600)
const totalMins = Math.floor((totalDuration % 3600) / 60)
const maxSpeed = Math.max(...ski.map(d => d.top_speed_kmh || 0))
const maxSpeedDay = ski.find(d => d.top_speed_kmh === maxSpeed)
const maxAlt = Math.max(...ski.map(d => d.peak_altitude_m || 0))
const maxAltDay = ski.find(d => d.peak_altitude_m === maxAlt)
const totalLifts = ski.reduce((s, d) => s + (d.lifts || 0), 0)
const resorts = [...new Set(ski.map(d => d.resort.split('/')[0].trim()))].length

// 月份分布
const monthCount: Record<string, number> = {}
ski.forEach(d => {
  const m = d.date.slice(0, 7)
  monthCount[m] = (monthCount[m] || 0) + 1
})
const months = Object.keys(monthCount).sort()

// 年度比較資料
const yearMap: Record<string, number> = {}
ski.forEach(d => {
  const y = d.date.slice(0, 4)
  yearMap[y] = (yearMap[y] || 0) + 1
})
const yearLabels = Object.keys(yearMap).sort()
const skiYearData = {
  labels: yearLabels,
  days: yearLabels.map(y => yearMap[y]),
}
---

<Layout title="滑雪紀錄" description={`${totalDays} 天滑雪 · 最高速 ${maxSpeed.toFixed(1)}km/h · 累計落差 ${(totalVertical/1000).toFixed(1)}km`} ogImage="/og/ski.png">
  <PageHeader title="⛷️ 滑雪紀錄" subtitle="日本雪場巡禮" />

  <!-- 統計卡片 -->
  <div class="grid grid-cols-2 md:grid-cols-5 gap-4 mb-10">
    <StatCard value={totalDays} label="滑雪天數" target={totalDays} delay={1} color="#84e7a5" />
    <StatCard value={totalRuns} label="總滑行次數" target={totalRuns} delay={2} color="#84e7a5" />
    <StatCard value={`${(totalVertical/1000).toFixed(1)}km`} label="累計垂直落差" target={totalVertical/1000} decimals={1} suffix="km" delay={3} color="#84e7a5" />
    <StatCard value={`${maxSpeed.toFixed(1)}km/h`} label="最高速度" sub={maxSpeedDay?.resort} target={maxSpeed} decimals={1} suffix="km/h" delay={4} color="#84e7a5" />
    <StatCard value={`${totalHours}h ${totalMins}m`} label="總滑行時間" target={totalHours} suffix={`h ${totalMins}m`} delay={5} color="#84e7a5" />
    <StatCard value={`${maxAlt.toFixed(0)}m`} label="最高海拔" sub={maxAltDay?.resort} target={maxAlt} suffix="m" delay={6} color="#84e7a5" />
    <StatCard value={`${(totalDistance/1000).toFixed(1)}km`} label="總滑行距離" target={totalDistance/1000} decimals={1} suffix="km" delay={7} color="#84e7a5" />
    <StatCard value={totalLifts} label="總搭纜車次數" target={totalLifts} delay={8} color="#84e7a5" />
    <StatCard value={resorts} label="造訪雪場" target={resorts} delay={8} color="#84e7a5" />
  </div>

  <!-- 地圖 -->
  <MapSection id="ski-map" title="雪場地圖" />

  <!-- 圖表區 -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-12">
    <!-- 速度分布 -->
    <div class="bg-surface border border-border rounded-xl p-6">
      <h3 class="text-[0.9rem] text-muted mt-0 mb-4 font-semibold">各天最高速度 <span class="text-[0.68rem] bg-pill-indigo text-indigo px-[0.4rem] py-[0.15rem] rounded align-middle">km/h</span></h3>
      <div class="relative h-45 md:h-55">
        <canvas data-chart="speed"></canvas>
      </div>
    </div>
    <!-- 月份分布 -->
    <div class="bg-surface border border-border rounded-xl p-6">
      <h3 class="text-[0.9rem] text-muted mt-0 mb-4 font-semibold">月份滑雪天數</h3>
      <div class="relative h-45 md:h-55">
        <canvas data-chart="month"></canvas>
      </div>
    </div>
    <!-- 速度 vs 垂直落差 散點圖 -->
    <div class="bg-surface border border-border rounded-xl p-6">
      <h3 class="text-[0.9rem] text-muted mt-0 mb-4 font-semibold">速度 vs 垂直落差 <span class="text-[0.68rem] bg-pill-indigo text-indigo px-[0.4rem] py-[0.15rem] rounded align-middle">scatter</span></h3>
      <div class="relative h-45 md:h-55">
        <canvas data-chart="scatter"></canvas>
      </div>
    </div>
    <!-- 雪場比較橫條圖 -->
    <div class="bg-surface border border-border rounded-xl p-6">
      <h3 class="text-[0.9rem] text-muted mt-0 mb-4 font-semibold">雪場總滑行次數 <span class="text-[0.68rem] bg-pill-indigo text-indigo px-[0.4rem] py-[0.15rem] rounded align-middle">runs</span></h3>
      <div class="relative h-45 md:h-55">
        <canvas data-chart="resort"></canvas>
      </div>
    </div>
    <!-- 年度比較 grouped bar chart -->
    <div class="bg-surface border border-border rounded-xl p-6 col-span-full">
      <h3 class="text-[0.9rem] text-muted mt-0 mb-4 font-semibold">年度比較 <span class="text-[0.68rem] bg-pill-indigo text-indigo px-[0.4rem] py-[0.15rem] rounded align-middle">滑雪天數 vs 總 runs</span></h3>
      <div class="relative" style="height:200px;">
        <canvas data-chart="year-compare"></canvas>
      </div>
    </div>
  </div>

  <!-- 滑雪列表 -->
  <div class="mb-12">
    <h2>所有紀錄</h2>

    <!-- 篩選列 -->
    <div class="flex items-center gap-3 mb-4 flex-wrap">
      <input
        data-ref="search"
        type="search"
        placeholder="搜尋雪場名稱…"
        class="flex-1 min-w-45 bg-surface border-border rounded-lg text-muted px-[0.85rem] py-2 text-[0.88rem] outline-none transition-colors duration-200 placeholder:text-subtle focus:border-[#84e7a5]"
        autocomplete="off"
      />
      <select data-ref="year-select" class="bg-surface border-border rounded-lg text-muted px-3 py-2 text-[0.88rem] outline-none cursor-pointer transition-colors duration-200 focus:border-[#84e7a5]">
        <option value="">全部年份</option>
        <option value="2024">2024</option>
        <option value="2025">2025</option>
        <option value="2026">2026</option>
      </select>
      <span data-ref="count" class="text-[0.78rem] text-faint whitespace-nowrap ml-auto">顯示 {ski.length} / {ski.length} 筆</span>
    </div>

    <div class="flex flex-col gap-[0.6rem]">
      {ski.map(d => (
        <div class="ski-row bg-surface border-border rounded-xl flex items-center flex-wrap gap-2 py-3 px-4 md:flex-nowrap md:gap-4 md:py-4 md:px-6 transition-all duration-[250ms] hover:border-[#84e7a5] hover:-translate-y-0.5 hover:shadow-[-3px_5px_0px_#84e7a5] reveal">
          <div class="ski-date text-[0.8rem] text-faint md:min-w-[6rem] font-bold">{d.date}</div>
          <div class="ski-info flex-1 min-w-0">
            <div class="ski-resort font-semibold text-[0.95rem]">{d.resort}</div>
            <div class="text-[0.78rem] text-subtle mt-[0.1rem]">{d.country}</div>
          </div>
          <div class="ski-stats flex gap-[0.4rem] flex-wrap w-full md:w-auto">
            <span class="px-[0.6rem] py-[0.2rem] rounded-full text-[0.75rem] font-semibold whitespace-nowrap bg-pill-indigo text-indigo">🎿 {d.runs} runs</span>
            <span class="px-[0.6rem] py-[0.2rem] rounded-full text-[0.75rem] font-semibold whitespace-nowrap bg-pill-indigo text-indigo-light">🚡 {d.lifts} lifts</span>
            <span class="px-[0.6rem] py-[0.2rem] rounded-full text-[0.75rem] font-semibold whitespace-nowrap bg-pill-cyan text-accent">↕ {(d.vertical_m / 1000).toFixed(2)}km</span>
            <span class="px-[0.6rem] py-[0.2rem] rounded-full text-[0.75rem] font-semibold whitespace-nowrap bg-pill-green text-green">📏 {(d.distance_m / 1000).toFixed(1)}km</span>
            <span class="px-[0.6rem] py-[0.2rem] rounded-full text-[0.75rem] font-semibold whitespace-nowrap bg-pill-red text-red">💨 {d.top_speed_kmh.toFixed(1)}km/h</span>
            <span class="px-[0.6rem] py-[0.2rem] rounded-full text-[0.75rem] font-semibold whitespace-nowrap bg-pill-teal text-teal">⏱ {Math.floor(d.duration_s/3600)}h{Math.floor((d.duration_s%3600)/60)}m</span>
            <span class="px-[0.6rem] py-[0.2rem] rounded-full text-[0.75rem] font-semibold whitespace-nowrap bg-pill-amber text-amber">🏔 {d.peak_altitude_m.toFixed(0)}m</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>

<script define:vars={{ ski, months, monthCount, totalCount: ski.length, skiYearData }} is:inline>
  window.__SKI_DATA__ = ski
  window.__SKI_MONTHS__ = months
  window.__SKI_MONTH_COUNT__ = monthCount
  window.__SKI_TOTAL__ = totalCount
  window.__SKI_YEAR_DATA__ = skiYearData
</script>

<script>
  import '../scripts/ski-app.ts'
  import '../scripts/count-up.ts'
</script>
