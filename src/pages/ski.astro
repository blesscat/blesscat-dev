---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import StatCard from '../components/StatCard.astro';
import MapSection from '../components/MapSection.astro';
import skiRaw from '../data/ski.json';

const ski = skiRaw as any[];

const totalDays = ski.length;
const totalRuns = ski.reduce((s, d) => s + (d.runs || 0), 0);
const totalVertical = ski.reduce((s, d) => s + (d.vertical_m || 0), 0);
const totalDistance = ski.reduce((s, d) => s + (d.distance_m || 0), 0);
const totalDuration = ski.reduce((s, d) => s + (d.duration_s || 0), 0);
const totalHours = Math.floor(totalDuration / 3600);
const totalMins = Math.floor((totalDuration % 3600) / 60);
const maxSpeed = Math.max(...ski.map(d => d.top_speed_kmh || 0));
const maxSpeedDay = ski.find(d => d.top_speed_kmh === maxSpeed);
const maxAlt = Math.max(...ski.map(d => d.peak_altitude_m || 0));
const maxAltDay = ski.find(d => d.peak_altitude_m === maxAlt);
const totalLifts = ski.reduce((s, d) => s + (d.lifts || 0), 0);
const resorts = [...new Set(ski.map(d => d.resort.split('/')[0].trim()))].length;

// 月份分布
const monthCount: Record<string, number> = {};
ski.forEach(d => {
  const m = d.date.slice(0, 7);
  monthCount[m] = (monthCount[m] || 0) + 1;
});
const months = Object.keys(monthCount).sort();

// 年度比較資料
const yearMap: Record<string, number> = {};
ski.forEach(d => {
  const y = d.date.slice(0, 4);
  yearMap[y] = (yearMap[y] || 0) + 1;
});
const yearLabels = Object.keys(yearMap).sort();
const skiYearData = {
  labels: yearLabels,
  days: yearLabels.map(y => yearMap[y]),
};
---

<Layout title="滑雪紀錄" description={`${totalDays} 天滑雪 · 最高速 ${maxSpeed.toFixed(1)}km/h · 累計落差 ${(totalVertical/1000).toFixed(1)}km`} ogImage="/og/ski.png">
  <PageHeader title="⛷️ 滑雪紀錄" subtitle="日本雪場巡禮" />

  <!-- 統計卡片 -->
  <div class="stats-grid">
    <StatCard value={totalDays} label="滑雪天數" target={totalDays} delay={1} color="#818cf8" />
    <StatCard value={totalRuns} label="總滑行次數" target={totalRuns} delay={2} color="#818cf8" />
    <StatCard value={`${(totalVertical/1000).toFixed(1)}km`} label="累計垂直落差" target={totalVertical/1000} decimals={1} suffix="km" delay={3} color="#818cf8" />
    <StatCard value={`${maxSpeed.toFixed(1)}km/h`} label="最高速度" sub={maxSpeedDay?.resort} target={maxSpeed} decimals={1} suffix="km/h" delay={4} color="#818cf8" />
    <StatCard value={`${totalHours}h ${totalMins}m`} label="總滑行時間" target={totalHours} suffix={`h ${totalMins}m`} delay={5} color="#818cf8" />
    <StatCard value={`${maxAlt.toFixed(0)}m`} label="最高海拔" sub={maxAltDay?.resort} target={maxAlt} suffix="m" delay={6} color="#818cf8" />
    <StatCard value={`${(totalDistance/1000).toFixed(1)}km`} label="總滑行距離" target={totalDistance/1000} decimals={1} suffix="km" delay={7} color="#818cf8" />
    <StatCard value={totalLifts} label="總搭纜車次數" target={totalLifts} delay={8} color="#818cf8" />
    <StatCard value={resorts} label="造訪雪場" target={resorts} delay={8} color="#818cf8" />
  </div>

  <!-- 地圖 -->
  <MapSection id="ski-map" title="雪場地圖" />

  <!-- 圖表區 -->
  <div class="charts-grid section">
    <!-- 速度分布 -->
    <div class="card chart-card">
      <h3>各天最高速度 <span class="badge">km/h</span></h3>
      <div class="chart-wrapper">
        <canvas id="speed-chart"></canvas>
      </div>
    </div>
    <!-- 月份分布 -->
    <div class="card chart-card">
      <h3>月份滑雪天數</h3>
      <div class="chart-wrapper">
        <canvas id="month-chart"></canvas>
      </div>
    </div>
    <!-- 速度 vs 垂直落差 散點圖 -->
    <div class="card chart-card">
      <h3>速度 vs 垂直落差 <span class="badge">scatter</span></h3>
      <div class="chart-wrapper">
        <canvas id="scatter-chart"></canvas>
      </div>
    </div>
    <!-- 雪場比較橫條圖 -->
    <div class="card chart-card">
      <h3>雪場總滑行次數 <span class="badge">runs</span></h3>
      <div class="chart-wrapper">
        <canvas id="resort-chart"></canvas>
      </div>
    </div>
    <!-- 年度比較 grouped bar chart -->
    <div class="card chart-card chart-card--full">
      <h3>年度比較 <span class="badge">滑雪天數 vs 總 runs</span></h3>
      <div class="chart-wrapper" style="height:200px;">
        <canvas id="year-compare-chart"></canvas>
      </div>
    </div>
  </div>

  <!-- 滑雪列表 -->
  <div class="section">
    <h2>所有紀錄</h2>

    <!-- 篩選列 -->
    <div class="filter-bar">
      <input
        id="ski-search"
        type="search"
        placeholder="搜尋雪場名稱…"
        class="filter-input"
        autocomplete="off"
      />
      <select id="ski-year" class="filter-select">
        <option value="">全部年份</option>
        <option value="2024">2024</option>
        <option value="2025">2025</option>
        <option value="2026">2026</option>
      </select>
      <span id="ski-count" class="filter-count">顯示 {ski.length} / {ski.length} 筆</span>
    </div>

    <div class="ski-list">
      {ski.map(d => (
        <div class="ski-row card reveal">
          <div class="ski-date">{d.date}</div>
          <div class="ski-info">
            <div class="ski-resort">{d.resort}</div>
            <div class="ski-country">{d.country}</div>
          </div>
          <div class="ski-stats">
            <span class="pill runs">🎿 {d.runs} runs</span>
            <span class="pill lifts">🚡 {d.lifts} lifts</span>
            <span class="pill vert">↕ {(d.vertical_m / 1000).toFixed(2)}km</span>
            <span class="pill dist">📏 {(d.distance_m / 1000).toFixed(1)}km</span>
            <span class="pill speed">💨 {d.top_speed_kmh.toFixed(1)}km/h</span>
            <span class="pill time">⏱ {Math.floor(d.duration_s/3600)}h{Math.floor((d.duration_s%3600)/60)}m</span>
            <span class="pill alt">🏔 {d.peak_altitude_m.toFixed(0)}m</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>

<script define:vars={{ ski, months, monthCount, totalCount: ski.length, skiYearData }} is:inline>
  window.__SKI_DATA__ = ski;
  window.__SKI_MONTHS__ = months;
  window.__SKI_MONTH_COUNT__ = monthCount;
  window.__SKI_TOTAL__ = totalCount;
  window.__SKI_YEAR_DATA__ = skiYearData;
</script>

<script>
  import '../scripts/ski-app.ts';
  import '../scripts/count-up.ts';
</script>

<style>
  .page-header { margin-bottom: 2rem; }
  .subtitle { color: #64748b; margin-top: 0.3rem; }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .card {
    background: #111827;
    border: 1px solid #1e2535;
    border-radius: 12px;
    padding: 1.5rem;
  }
  .stat-card { text-align: center; }
  .stat-num { font-size: 1.8rem; font-weight: 800; color: #818cf8; }
  .stat-unit { font-size: 0.9rem; font-weight: 600; }
  .stat-label { font-size: 0.75rem; color: #64748b; text-transform: uppercase; letter-spacing: 1px; margin-top: 0.25rem; }
  .stat-sub { font-size: 0.72rem; color: #475569; margin-top: 0.2rem; }
  .section { margin-bottom: 3rem; }
  .map-container { height: 450px; border-radius: 12px; overflow: hidden; border: 1px solid #1e2535; }

  /* 圖表區 */
  .charts-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .chart-card h3 { font-size: 0.9rem; color: #94a3b8; margin: 0 0 1rem; font-weight: 600; }
  .chart-card--full { grid-column: 1 / -1; }
  .badge {
    font-size: 0.68rem; background: #1e1a2e; color: #818cf8;
    padding: 0.15rem 0.4rem; border-radius: 4px; vertical-align: middle;
  }
  .chart-wrapper { position: relative; height: 220px; }

  /* 篩選列 */
  .filter-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .filter-input {
    flex: 1;
    min-width: 180px;
    background: #111827;
    border: 1px solid #1e2535;
    border-radius: 8px;
    color: #94a3b8;
    padding: 0.5rem 0.85rem;
    font-size: 0.88rem;
    outline: none;
    transition: border-color 0.2s;
  }
  .filter-input::placeholder { color: #475569; }
  .filter-input:focus { border-color: #818cf8; }
  .filter-select {
    background: #111827;
    border: 1px solid #1e2535;
    border-radius: 8px;
    color: #94a3b8;
    padding: 0.5rem 0.75rem;
    font-size: 0.88rem;
    outline: none;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .filter-select:focus { border-color: #818cf8; }
  .filter-count {
    font-size: 0.78rem;
    color: #475569;
    white-space: nowrap;
    margin-left: auto;
  }

  /* 列表 */
  .ski-list { display: flex; flex-direction: column; gap: 0.6rem; }
  .ski-row {
    display: flex; align-items: center; gap: 1rem;
    padding: 1rem 1.5rem;
    transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
  }
  .ski-row:hover {
    border-color: #818cf8;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(129,140,248,0.1);
  }
  .ski-date { font-size: 0.8rem; color: #475569; min-width: 6rem; font-weight: 700; }
  .ski-info { flex: 1; min-width: 0; }
  .ski-resort { font-weight: 600; font-size: 0.95rem; }
  .ski-country { font-size: 0.78rem; color: #64748b; margin-top: 0.1rem; }
  .ski-stats { display: flex; gap: 0.4rem; flex-wrap: wrap; }
  .pill { padding: 0.2rem 0.6rem; border-radius: 99px; font-size: 0.75rem; font-weight: 600; white-space: nowrap; }
  .pill.runs  { background: #1e1a2e; color: #818cf8; }
  .pill.vert  { background: #0c2d48; color: #38bdf8; }
  .pill.dist  { background: #1a2e1a; color: #4ade80; }
  .pill.speed { background: #2e1a1a; color: #f87171; }
  .pill.time  { background: #1a2520; color: #34d399; }
  .pill.alt   { background: #1e1a10; color: #fbbf24; }
  .pill.lifts { background: #1a1e2e; color: #a5b4fc; }

  @media (max-width: 768px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .map-container { height: 280px; }
    .charts-grid { grid-template-columns: 1fr; }
    .chart-wrapper { height: 180px; }
    .ski-row { flex-wrap: wrap; gap: 0.5rem; padding: 0.75rem 1rem; }
    .ski-date { min-width: auto; }
    .ski-stats { width: 100%; }
  }
</style>
